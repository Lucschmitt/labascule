---
import { u } from '../config';
const { title, description } = Astro.props;
const path = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — La Bascule</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --ink:        #1a1814;
      --ink-light:  #4a4540;
      --ink-faint:  #8a8480;
      --paper:      #f5f2eb;
      --paper-dark: #ede9e0;
      --rule:       #d4cfc4;

      --signal-none:    #2d5a27;
      --signal-low:     #7a6200;
      --signal-mid:     #8a3a00;
      --signal-high:    #7a1500;
      --signal-crit:    #5a0000;

      --bg-none:    #eaf3e8;
      --bg-low:     #fef8e1;
      --bg-mid:     #fef0e1;
      --bg-high:    #fde8e8;
      --bg-crit:    #f5d5d5;

      --serif:   'Source Serif 4', Georgia, serif;
      --display: 'Playfair Display', Georgia, serif;
      --mono:    'IBM Plex Mono', 'Courier New', monospace;

      --max-w: 900px;
      --col-gap: 2rem;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 17px; background: var(--paper); color: var(--ink); }

    body {
      font-family: var(--serif);
      font-weight: 300;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* ── Header ── */
    .site-header {
      border-bottom: 2px solid var(--ink);
      padding: 1.5rem 2rem;
      display: flex;
      align-items: baseline;
      gap: 2rem;
      background: var(--paper);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .site-logo {
      font-family: var(--display);
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
      text-decoration: none;
      white-space: nowrap;
    }

    .site-logo span {
      font-style: italic;
      font-weight: 400;
    }

    .site-nav {
      display: flex;
      gap: 1.5rem;
      list-style: none;
    }

    .site-nav a {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-light);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 1px;
      transition: color 0.15s, border-color 0.15s;
    }

    .site-nav a:hover,
    .site-nav a.active {
      color: var(--ink);
      border-bottom-color: var(--ink);
    }

    .site-nav a.active {
      font-weight: 500;
    }

    /* ── Main ── */
    main {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    /* ── Footer ── */
    .site-footer {
      border-top: 1px solid var(--rule);
      padding: 2rem;
      text-align: center;
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      color: var(--ink-faint);
    }

    .site-footer a {
      color: var(--ink-light);
    }

    /* ── Typography helpers ── */
    h1 {
      font-family: var(--display);
      font-size: 2.6rem;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    h2 {
      font-family: var(--display);
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 2.5rem 0 1rem;
    }

    .lead {
      font-size: 1.1rem;
      color: var(--ink-light);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    .label {
      font-family: var(--mono);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
    }

    /* ── Signal badges ── */
    .signal {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 500;
      padding: 0.25rem 0.6rem;
      border-radius: 2px;
    }

    .signal::before {
      content: '';
      display: block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    .signal-none   { color: var(--signal-none); background: var(--bg-none); }
    .signal-faible { color: var(--signal-low);  background: var(--bg-low); }
    .signal-modere { color: var(--signal-mid);  background: var(--bg-mid); }
    .signal-fort   { color: var(--signal-high); background: var(--bg-high); }
    .signal-crit   { color: var(--signal-crit); background: var(--bg-crit); }

    /* ── Score bar ── */
    .score-bar-wrap {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .score-bar {
      flex: 1;
      height: 4px;
      background: var(--rule);
      border-radius: 2px;
      overflow: hidden;
    }

    .score-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
    }

    .score-value {
      font-family: var(--mono);
      font-size: 0.9rem;
      font-weight: 500;
      min-width: 3.5rem;
      text-align: right;
    }

    /* ── Utilities ── */
    .divider {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 2.5rem 0;
    }

    @media (max-width: 640px) {
      .site-header { flex-wrap: wrap; gap: 1rem; }
      h1 { font-size: 1.8rem; }
      main { padding: 2rem 1.25rem 4rem; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href={u('/')} class="site-logo">La <span>Bascule</span></a>
    <nav>
      <ul class="site-nav">
        <li><a href={u('/')} class={path === u('/') || path === u('') || path === BASE + '/' ? 'active' : ''}>Frise</a></li>
        <li><a href={u('/barometre/')} class={path.includes('/barometre') ? 'active' : ''}>Baromètre</a></li>
        <li><a href={u('/methode/')} class={path.includes('/methode') ? 'active' : ''}>Méthode</a></li>
        <li><a href="https://github.com/lucschmitt/labascule" target="_blank" rel="noopener">GitHub ↗</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>
      La Bascule — Observatoire citoyen indépendant — Luc Schmitt —
      <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
    </p>
  </footer>
</body>
</html>
