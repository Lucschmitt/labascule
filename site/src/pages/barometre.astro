---
import Base from '../layouts/Base.astro';
import FicheCard from '../components/FicheCard.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import { computeDashboard, CRITERES_C_LABELS, COLORS } from '../lib/dashboard.js';

let fiches = [];
let etalons = [];

try {
  const fichesDir = join(process.cwd(), 'public', 'fiches');
  const files = await readdir(fichesDir).catch(() => []);
  const jsonFiles = files.filter(f => f.endsWith('.json'));
  const allFiches = await Promise.all(
    jsonFiles.map(async f => {
      const raw = await readFile(join(fichesDir, f), 'utf-8');
      return JSON.parse(raw);
    })
  );
  fiches = allFiches
    .filter(f => f.statut !== 'calibration-historique')
    .sort((a, b) => new Date(b.date_analyse) - new Date(a.date_analyse));
  etalons = allFiches
    .filter(f => f.statut === 'calibration-historique')
    .sort((a, b) => (b.scoring?.score_total || 0) - (a.scoring?.score_total || 0));
} catch (e) {}

let stripes  = [];
let vector   = { deltaInst: 0, deltaRhet: 0, force: 0, nActive: 0, color: '#1D9E75', hasCurrent: false, hasPrevious: false, angle: 0 };
let criteres = [];
let metrics  = { avgL: null, avgC: null, signal: 'Vert', signalSub: 'Aucun signal détecté', signalColor: '#1D9E75', nFiches: 0 };

try {
  const fichesDir = join(process.cwd(), 'public', 'fiches');
  const allFiles = await readdir(fichesDir, { recursive: true }).catch(() => []);
  const jsonFiles = allFiles.filter(f => f.endsWith('.json') && !f.includes('calibration'));
  const fichesDB = (
    await Promise.all(
      jsonFiles.map(async f => {
        try { const raw = await readFile(join(fichesDir, f), 'utf-8'); return JSON.parse(raw); }
        catch { return null; }
      })
    )
  ).filter(Boolean).filter(f => f.statut !== 'calibration-historique');
  ({ stripes, vector, criteres, metrics } = computeDashboard(fichesDB));
} catch (e) {}

const stripesJson  = JSON.stringify(stripes);
const vectorJson   = JSON.stringify(vector);
const criteresJson = JSON.stringify(criteres);
const metricsJson  = JSON.stringify(metrics);
const labelsJson   = JSON.stringify(CRITERES_C_LABELS);
const colorsJson   = JSON.stringify(COLORS);

function signalClass(signal) {
  const map = { 'critique': 'signal-crit', 'fort': 'signal-fort', 'modéré': 'signal-modere', 'faible': 'signal-faible', 'aucun': 'signal-none' };
  return map[signal] || 'signal-none';
}
---

<Base
  title="Baromètre législatif"
  description="Baromètre des textes législatifs français analysés selon la grille de similitude structurelle avec les séquences historiques de bascule autoritaire."
>

<!-- ═══════════════════════════════════════════════════════════════════════
     HERO — ~45vh, layout 4 colonnes, fond sombre
     ═══════════════════════════════════════════════════════════════════════ -->
<div slot="hero" class="hero" id="hero" role="region" aria-label="Tableau de bord de surveillance">

  <!-- Bandeau titre fin -->
  <div class="hero__bar">
    <span class="hero__title">Signaux &amp; tendances</span>
    <span class="hero__period" id="hero-period-value" aria-live="polite"></span>
    <span class="hero__tag">prototype v0.2</span>
  </div>

  <!-- Corps : 4 colonnes -->
  <div class="hero__body">

    <!-- Col A — KPIs verticaux -->
    <div class="hero__kpis" role="list" aria-label="Indicateurs synthétiques">

      <div class="kpi" role="listitem">
        <span class="kpi__label" id="lbl-avgL">Score L<br><span class="kpi__sub">3 mois · législatif</span></span>
        <span class="kpi__value" id="card-avgL" aria-labelledby="lbl-avgL" aria-live="polite">—</span>
      </div>

      <div class="kpi__sep" aria-hidden="true"></div>

      <div class="kpi" role="listitem">
        <span class="kpi__label" id="lbl-avgC">Score C<br><span class="kpi__sub">3 mois · contextuel</span></span>
        <span class="kpi__value" id="card-avgC" aria-labelledby="lbl-avgC" aria-live="polite">—</span>
      </div>

      <div class="kpi__sep" aria-hidden="true"></div>

      <div class="kpi kpi--signal" id="kpi-signal" role="listitem">
        <span class="kpi__label" id="lbl-signal">Signal</span>
        <span class="kpi__value kpi__value--signal" id="card-signal-value" aria-labelledby="lbl-signal" aria-live="polite">—</span>
        <span class="kpi__sub kpi__sub--signal" id="card-signal-sub" aria-live="polite"></span>
      </div>

    </div>

    <!-- Col B — Stripes + vecteur empilés -->
    <div class="hero__center">

      <div class="hero__stripes" role="figure" aria-labelledby="lbl-stripes">
        <p class="hz-label" id="lbl-stripes">Intensité mensuelle — score L</p>
        <canvas id="canvas-stripes" height="44"
          aria-label="Bandes colorées : intensité mensuelle des signaux législatifs. Teal = faible, orange-rouge = fort."></canvas>
        <div class="stripes-axis" id="stripes-axis" aria-hidden="true"></div>
        <div class="stripes-legend" aria-hidden="true">
          <canvas id="canvas-legend" width="110" height="7"></canvas>
          <span class="stripes-legend__lo">0%</span>
          <span class="stripes-legend__hi">100%</span>
        </div>
      </div>

      <div class="hero__vector" role="figure" aria-labelledby="lbl-vector">
        <p class="hz-label" id="lbl-vector">Vecteur de progression — dérivée 3 mois</p>
        <div class="vector-row">
          <canvas id="canvas-vector" width="160" height="160"
            aria-label="Diagramme vectoriel : axe vertical = diffusion institutionnelle (Paxton 2004), axe horizontal = rhétorique (Levitsky & Ziblatt 2018). Épaisseur de la flèche = critères C activés."></canvas>
          <div class="vector-stats">
            <div class="vstat">
              <span class="vstat__label" id="lbl-force">Force</span>
              <span class="vstat__value" id="vector-force" aria-labelledby="lbl-force" aria-live="polite">—</span>
            </div>
            <div class="vstat">
              <span class="vstat__label" id="lbl-deriv">Dérivée</span>
              <span class="vstat__value" id="vector-deriv" aria-labelledby="lbl-deriv" aria-live="polite">—</span>
            </div>
            <p class="vstat__ref">
              ↑ Institutionnel<br>
              → Rhétorique<br>
              ∿ Épaisseur = C actifs
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Col C — Critères C-03 à C-07 -->
    <div class="hero__criteres" role="figure" aria-labelledby="lbl-crit-a">
      <p class="hz-label" id="lbl-crit-a">Critères C · 6 mois <span class="hz-label__sub">C-03–07</span></p>
      <div class="crit-list" id="criteres-list-a" role="list"
        aria-label="Taux d'activation C-03 à C-07 sur 6 mois glissants"></div>
      <p class="crit-foot">▇ courant · ░ précédent</p>
    </div>

    <!-- Col D — Critères C-08 à C-12 -->
    <div class="hero__criteres" role="figure" aria-labelledby="lbl-crit-b">
      <p class="hz-label" id="lbl-crit-b">Critères C · 6 mois <span class="hz-label__sub">C-08–12</span></p>
      <div class="crit-list" id="criteres-list-b" role="list"
        aria-label="Taux d'activation C-08 à C-12 sur 6 mois glissants"></div>
      <p class="crit-foot">Fenêtre 6 mois — seuil canonique (CDC/ECDC · Levitsky &amp; Ziblatt 2018)</p>
    </div>

  </div><!-- /hero__body -->
</div><!-- /hero -->

<!-- ═══════════════════════════════════════════════════════════════════════
     CONTENU (inchangé)
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="content-zone">

  <div class="page-header">
    <p class="label">Baromètre législatif</p>
    <h1>Analyses en cours</h1>
    <p class="lead">
      Chaque texte est analysé par un pipeline de 4 agents IA indépendants
      selon la grille de 17 critères académiques.
      Les scores mesurent des <strong>similitudes de mécanisme</strong> avec les
      séquences historiques de référence — non une qualification politique des auteurs.
    </p>
  </div>

  <hr class="divider" />

  <div class="dashboard">
    <div class="dash-item">
      <span class="dash-value">{fiches.length}</span>
      <span class="label">Fiches publiées</span>
    </div>
    <div class="dash-item">
      <span class="dash-value">{fiches.filter(f => f.symetrie?.statut === 'planifiee').length}</span>
      <span class="label">Analyses symétriques en cours</span>
    </div>
    <div class="dash-item">
      <span class="dash-value">v0.1.0</span>
      <span class="label">Version de la grille</span>
    </div>
  </div>

  <hr class="divider" />

  <h2>Textes contemporains</h2>
  <div class="fiches-grid">
    {fiches.map(fiche => <FicheCard fiche={fiche} />)}
  </div>
  {fiches.length === 0 && (
    <p class="empty-state">
      Aucune fiche publiée — copiez les fichiers JSON dans <code>public/fiches/</code>
    </p>
  )}

  <hr class="divider" />

  <h2>Étalons de calibration</h2>
  <p class="lead" style="font-size: 0.9rem; margin-bottom: 1.5rem;">
    Ces textes historiques servent à valider la grille.
    Un score de 100% est attendu sur les textes fondateurs de la dictature.
  </p>
  <div class="etalons-list">
    {etalons.map(fiche => (
      <div class="etalon-row">
        <div class="etalon-meta">
          <span class={`signal ${signalClass(fiche.scoring?.position_frise?.signal)}`}>
            {fiche.scoring?.position_frise?.signal || '—'}
          </span>
          <span class="etalon-ref">{fiche.source?.reference?.substring(0, 80)}</span>
        </div>
        <div class="score-bar-wrap" style="max-width: 280px;">
          <div class="score-bar">
            <div class="score-bar-fill" style={`width: ${(fiche.scoring?.score_total || 0) * 100}%; background: var(--signal-crit)`}></div>
          </div>
          <span class="score-value" style="color: var(--signal-crit)">
            {Math.round((fiche.scoring?.score_total || 0) * 100)}%
          </span>
        </div>
      </div>
    ))}
  </div>

  <hr class="divider" />

  <div class="method-note">
    <p class="label">Note méthodologique</p>
    <p>
      Les critères C-03, C-04, C-05, C-06, C-07 sont des critères contextuels
      non évaluables sur un texte législatif isolé. Les scores reflètent les critères
      applicables au texte analysé. <a href={`${import.meta.env.BASE_URL}/methode`}>Lire la méthode →</a>
    </p>
  </div>

</div>

</Base>

<!-- Panel -->
<div id="fiche-backdrop" class="fiche-backdrop" aria-hidden="true"></div>
<aside id="fiche-panel" class="fiche-panel" role="dialog" aria-modal="true" aria-label="Détail de la fiche" hidden>
  <div class="panel-inner">
    <button id="fiche-close" class="panel-close" aria-label="Fermer le panneau">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <line x1="2" y1="2" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="2" x2="2" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div id="fiche-content" class="panel-content"></div>
  </div>
</aside>

<style>
/* ═══════════════════════════════════════════════════════════════════════════
   PALETTE
   text-1 #d8d4cc  ratio ~10:1  — valeurs, titres
   text-2 #948f87  ratio ~4.5:1 — labels (WCAG AA)
   text-3 #66625c  ratio ~3:1   — annotations décoratives
   ═══════════════════════════════════════════════════════════════════════════ */

.hero {
  --h-bg:      #111110;
  --h-surf:    #191917;
  --h-border:  #2a2a27;
  --h-rule:    #1e1e1c;
  --h-t1:      #d8d4cc;
  --h-t2:      #948f87;
  --h-t3:      #5e5a54;

  background: var(--h-bg);
  color: var(--h-t1);
  font-family: var(--mono);
  width: 100%;
  box-sizing: border-box;

  /* ~45vh, jamais moins de 320px ni plus de 480px */
  height: clamp(320px, 46vh, 480px);
  overflow: hidden;           /* peeking : le contenu dépasse proprement */

  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Bandeau titre ── */
.hero__bar {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.55rem 1.75rem;
  border-bottom: 1px solid var(--h-rule);
  flex-shrink: 0;
}

.hero__title {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--h-t1);
}

.hero__period {
  font-size: 0.68rem;
  color: var(--h-t2);
  font-variant-numeric: tabular-nums;
  margin-left: auto;
}

.hero__tag {
  font-size: 0.62rem;
  color: var(--h-t3);
  letter-spacing: 0.05em;
}

/* ── Corps 4 colonnes ── */
.hero__body {
  display: grid;
  grid-template-columns: 140px 1fr 1fr 1fr;
  gap: 0;
  flex: 1;
  min-height: 0;
  border-top: none;
}

/* Séparateurs verticaux entre colonnes */
.hero__kpis,
.hero__center,
.hero__criteres {
  border-right: 1px solid var(--h-rule);
  padding: 0.9rem 1.1rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero__criteres:last-child {
  border-right: none;
}

/* ── Col A — KPIs ── */
.hero__kpis {
  gap: 0;
  justify-content: space-between;
}

.kpi {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.kpi__sep {
  height: 1px;
  background: var(--h-rule);
  margin: 0 0;
  flex-shrink: 0;
}

.kpi__label {
  font-size: 0.62rem;
  color: var(--h-t2);
  letter-spacing: 0.04em;
  line-height: 1.35;
}

.kpi__sub {
  font-size: 0.58rem;
  color: var(--h-t3);
  display: block;
  margin-top: 0.05rem;
}

.kpi__value {
  font-size: 1.85rem;
  font-weight: 500;
  line-height: 1;
  color: var(--h-t1);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.025em;
  margin-top: 0.2rem;
}

.kpi--signal { gap: 0.1rem; }

.kpi__value--signal {
  font-size: 1.35rem;
}

.kpi__sub--signal {
  font-size: 0.65rem;
  color: var(--h-t2);
  margin-top: 0.1rem;
  display: block;
}

/* ── Col B — Stripes + Vecteur ── */
.hero__center {
  gap: 0.7rem;
}

/* Labels de section partagés */
.hz-label {
  font-size: 0.61rem;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--h-t2);
  font-weight: 500;
  margin-bottom: 0.35rem;
  flex-shrink: 0;
}

.hz-label__sub {
  font-size: 0.9em;
  color: var(--h-t3);
  text-transform: none;
  letter-spacing: 0.02em;
  font-weight: 400;
}

/* Stripes */
.hero__stripes {
  flex-shrink: 0;
}

#canvas-stripes {
  display: block;
  width: 100%;
  border-radius: 2px;
  background: #252522;
}

.stripes-axis {
  display: flex;
  font-size: 0.58rem;
  color: var(--h-t2);
  margin-top: 3px;
  font-variant-numeric: tabular-nums;
  overflow: hidden;
}

.stripes-legend {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.3rem;
}

#canvas-legend { border-radius: 1px; flex-shrink: 0; }

.stripes-legend__lo,
.stripes-legend__hi {
  font-size: 0.58rem;
  color: var(--h-t3);
}

.stripes-legend__lo { margin-left: 0.2rem; }

/* Vecteur */
.hero__vector {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.vector-row {
  display: flex;
  gap: 0.65rem;
  align-items: flex-start;
  flex: 1;
  min-height: 0;
}

#canvas-vector {
  /* Taille pilotée par JS selon hauteur disponible */
  flex-shrink: 0;
  max-width: 140px;
  max-height: 140px;
  width: 140px;
  height: 140px;
}

.vector-stats {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
  min-width: 0;
  flex: 1;
  padding-top: 0.2rem;
}

.vstat {
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
}

.vstat__label {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--h-t2);
}

.vstat__value {
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--h-t1);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.01em;
}

.vstat__ref {
  font-size: 0.58rem;
  color: var(--h-t3);
  line-height: 1.55;
  margin-top: 0.3rem;
}

/* ── Cols C & D — Critères ── */
.hero__criteres {
  gap: 0;
}

.crit-list {
  display: flex;
  flex-direction: column;
  gap: 0.22rem;
  flex: 1;
  min-height: 0;
}

.crit-row {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-shrink: 0;
}

.crit-row__id {
  font-size: 0.64rem;
  font-weight: 500;
  width: 2.6rem;
  flex-shrink: 0;
  color: var(--h-t2);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
}

.crit-row__bars {
  position: relative;
  flex: 1;
  height: 12px;
  border-radius: 2px;
  background: var(--h-surf);
  border: 1px solid var(--h-border);
  overflow: hidden;
  cursor: help;
}

.crit-bar {
  position: absolute;
  top: 0; left: 0;
  height: 100%;
  border-radius: 1px;
}

.crit-bar--prev { opacity: 0.28; }

.crit-row__delta {
  font-size: 0.64rem;
  font-weight: 600;
  width: 2.8rem;
  text-align: right;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

.crit-foot {
  font-size: 0.58rem;
  color: var(--h-t3);
  line-height: 1.45;
  margin-top: 0.4rem;
  flex-shrink: 0;
}

.crit-empty {
  font-size: 0.72rem;
  color: var(--h-t2);
  font-style: italic;
}

/* ═══════════════════════════════════════════════════════════════════════════
   CONTENT ZONE
   ═══════════════════════════════════════════════════════════════════════════ */
.content-zone { padding-top: 2.5rem; }
.page-header { margin-bottom: 1rem; }
.dashboard { display: flex; gap: 2rem; flex-wrap: wrap; margin: 1.5rem 0; }
.dash-item { display: flex; flex-direction: column; gap: 0.2rem; }
.dash-value { font-family: var(--mono); font-size: 1.8rem; font-weight: 500; color: var(--ink); line-height: 1; }
.fiches-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1rem; }
.empty-state { color: var(--ink-faint); font-size: 0.9rem; padding: 2rem; text-align: center; border: 1px dashed var(--rule); border-radius: 4px; }
.etalons-list { display: flex; flex-direction: column; gap: 0.75rem; }
.etalon-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1rem; background: var(--paper-dark); border-radius: 2px; flex-wrap: wrap; }
.etalon-meta { display: flex; align-items: center; gap: 0.75rem; min-width: 0; }
.etalon-ref { font-size: 0.85rem; color: var(--ink-light); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; }
.method-note { font-size: 0.85rem; color: var(--ink-faint); background: var(--paper-dark); padding: 1rem 1.25rem; border-radius: 2px; }
.method-note .label { margin-bottom: 0.4rem; }
.method-note a { color: var(--ink-light); }

/* ═══════════════════════════════════════════════════════════════════════════
   PANEL
   ═══════════════════════════════════════════════════════════════════════════ */
.fiche-backdrop { display: none; position: fixed; inset: 0; background: rgba(26,24,20,.35); backdrop-filter: blur(2px); z-index: 200; opacity: 0; transition: opacity .25s ease; }
.fiche-backdrop.is-open { display: block; }
.fiche-backdrop.is-visible { opacity: 1; }
.fiche-panel { position: fixed; top: 0; right: 0; bottom: 0; width: min(560px, 100vw); background: var(--paper); border-left: 2px solid var(--ink); z-index: 201; transform: translateX(100%); transition: transform .3s cubic-bezier(.4,0,.2,1); display: flex; flex-direction: column; overflow: hidden; }
.fiche-panel:not([hidden]) { display: flex; }
.fiche-panel.is-open { transform: translateX(0); }
.panel-inner { display: flex; flex-direction: column; height: 100%; position: relative; }
.panel-close { position: absolute; top: 1.25rem; right: 1.25rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--paper-dark); border: 1px solid var(--rule); border-radius: 2px; color: var(--ink-light); cursor: pointer; transition: color .15s, border-color .15s; z-index: 10; }
.panel-close:hover { color: var(--ink); border-color: var(--ink-faint); }
.panel-content { flex: 1; overflow-y: auto; padding: 2rem 2rem 3rem; scroll-behavior: smooth; }

:global(.panel-signal-bar) { height: 4px; border-radius: 2px; margin: -2rem -2rem 1.5rem; }
:global(.panel-meta-row) { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-bottom: .75rem; }
:global(.panel-title) { font-family: var(--display); font-size: 1.3rem; font-weight: 700; line-height: 1.3; letter-spacing: -.01em; color: var(--ink); margin-bottom: .5rem; }
:global(.panel-sub) { font-family: var(--mono); font-size: .7rem; color: var(--ink-faint); letter-spacing: .06em; margin-bottom: 1.5rem; }
:global(.panel-score-block) { background: var(--paper-dark); border: 1px solid var(--rule); border-radius: 2px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1.5rem; }
:global(.panel-score-big) { font-family: var(--mono); font-size: 2.4rem; font-weight: 500; line-height: 1; min-width: 4.5rem; }
:global(.panel-score-detail) { font-family: var(--mono); font-size: .7rem; color: var(--ink-faint); line-height: 1.6; letter-spacing: .03em; }
:global(.panel-section) { margin-bottom: 1.75rem; }
:global(.panel-section-title) { font-family: var(--mono); font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-faint); border-bottom: 1px solid var(--rule); padding-bottom: .4rem; margin-bottom: 1rem; }
:global(.panel-parties) { display: flex; flex-direction: column; gap: .5rem; }
:global(.panel-party) { display: flex; gap: .75rem; padding: .6rem .75rem; background: var(--paper-dark); border-radius: 2px; font-size: .85rem; }
:global(.panel-party-nom) { font-weight: 400; color: var(--ink); min-width: 7rem; }
:global(.panel-party-role) { color: var(--ink-faint); font-size: .78rem; line-height: 1.4; }
:global(.contexte-text) { font-family: var(--serif); font-size: .85rem; color: var(--ink-light); line-height: 1.65; }
:global(.arg-list) { display: flex; flex-direction: column; gap: .85rem; }
:global(.arg-item) { border-left: 3px solid transparent; padding: .75rem .9rem; background: var(--paper-dark); border-radius: 0 2px 2px 0; }
:global(.arg-item.arg-fav) { border-left-color: var(--signal-none); }
:global(.arg-item.arg-def) { border-left-color: var(--signal-crit); }
:global(.arg-titre) { font-family: var(--serif); font-size: .88rem; font-weight: 400; color: var(--ink); margin-bottom: .4rem; }
:global(.arg-corps) { font-family: var(--serif); font-size: .8rem; color: var(--ink-light); line-height: 1.6; margin-bottom: .5rem; }
:global(.arg-sources) { display: flex; flex-wrap: wrap; gap: .3rem; }
:global(.arg-source-tag) { font-family: var(--mono); font-size: .6rem; color: var(--ink-faint); background: var(--paper); border: 1px solid var(--rule); padding: .1rem .4rem; border-radius: 2px; letter-spacing: .03em; }
:global(.critere-detail-list) { display: flex; flex-direction: column; gap: .6rem; }
:global(.critere-row) { display: grid; grid-template-columns: 2.5rem 1fr auto; gap: .75rem; align-items: start; padding: .6rem .75rem; background: var(--paper-dark); border-radius: 2px; font-size: .8rem; }
:global(.critere-id) { font-family: var(--mono); font-size: .7rem; font-weight: 500; color: var(--ink-light); letter-spacing: .04em; }
:global(.critere-justif) { font-family: var(--serif); color: var(--ink-light); line-height: 1.55; font-size: .8rem; }
:global(.critere-score-badge) { font-family: var(--mono); font-size: .7rem; font-weight: 500; padding: .15rem .4rem; border-radius: 2px; white-space: nowrap; }
:global(.badge-full) { background: var(--bg-crit); color: var(--signal-crit); }
:global(.badge-half) { background: var(--bg-mid); color: var(--signal-mid); }
:global(.badge-none) { background: var(--paper); color: var(--ink-faint); border: 1px solid var(--rule); }
:global(.badge-na)   { background: var(--paper); color: var(--ink-faint); border: 1px solid var(--rule); font-style: italic; }
:global(.panel-source-link) { display: inline-flex; align-items: center; gap: .35rem; font-family: var(--mono); font-size: .68rem; letter-spacing: .05em; color: var(--ink-light); text-decoration: none; border-bottom: 1px solid var(--rule); padding-bottom: 1px; transition: color .15s, border-color .15s; }
:global(.panel-source-link:hover) { color: var(--ink); border-color: var(--ink); }
:global(.symetrie-notice) { display: inline-flex; align-items: center; gap: .4rem; font-family: var(--mono); font-size: .68rem; color: var(--ink-faint); background: var(--paper-dark); border: 1px solid var(--rule); padding: .35rem .65rem; border-radius: 2px; }

/* Responsive */
@media (max-width: 900px) {
  .hero { height: auto; overflow: visible; }
  .hero__body { grid-template-columns: 120px 1fr 1fr; }
  .hero__criteres:last-child { grid-column: 2 / -1; border-top: 1px solid var(--h-rule); padding-top: 0.7rem; }
}

@media (max-width: 640px) {
  .hero__body { grid-template-columns: 1fr 1fr; }
  .hero__kpis { grid-column: 1 / -1; flex-direction: row; gap: 0.5rem; }
  .kpi__sep { width: 1px; height: auto; align-self: stretch; }
  .hero__center { grid-column: 1 / -1; }
  .fiches-grid { grid-template-columns: 1fr; }
  .fiche-panel { width: 100vw; }
  .panel-content { padding: 1.5rem 1.25rem 3rem; }
  :global(.panel-signal-bar) { margin-left: -1.25rem; margin-right: -1.25rem; }
}
</style>

<script define:vars={{ stripesJson, vectorJson, criteresJson, metricsJson, labelsJson, colorsJson }}>

  const stripes  = JSON.parse(stripesJson);
  const vector   = JSON.parse(vectorJson);
  const criteres = JSON.parse(criteresJson);
  const metrics  = JSON.parse(metricsJson);
  const LABELS   = JSON.parse(labelsJson);
  const COLORS   = JSON.parse(colorsJson);

  // Palette canvas synchronisée CSS
  const C = {
    bg:    '#111110', surf: '#191917', border: '#2a2a27',
    t1:    '#d8d4cc', t2:   '#948f87', t3:    '#5e5a54',
    grid:  'rgba(255,255,255,0.055)',
    axis:  'rgba(255,255,255,0.16)',
  };

  function pct(v, digits = 0) {
    if (v === null || v === undefined) return '—';
    return Math.round(v * 100) + '%';
  }

  function signed(v) {
    if (v === null || v === undefined) return '—';
    const s = Math.round(Math.abs(v) * 100);
    return (v >= 0 ? '+' : '−') + s + '%';
  }

  // ── CARDS ────────────────────────────────────────────────────────────
  function renderCards() {
    const MO = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
    const fmt = k => { const [y,m] = k.split('-').map(Number); return MO[m-1] + '\u202f' + String(y).slice(2); };

    const el = id => document.getElementById(id);

    const avgL = el('card-avgL');
    const avgC = el('card-avgC');
    const sigV = el('card-signal-value');
    const sigS = el('card-signal-sub');
    const sigK = el('kpi-signal');
    const per  = el('hero-period-value');

    if (avgL) avgL.textContent = metrics.avgL !== null ? pct(metrics.avgL) : '—';
    if (avgC) avgC.textContent = metrics.avgC !== null ? pct(metrics.avgC) : '—';
    if (sigV) { sigV.textContent = metrics.signal; sigV.style.color = metrics.signalColor; }
    if (sigS) sigS.textContent = metrics.signalSub;
    if (sigK) sigK.style.borderLeftColor = metrics.signalColor;
    if (per && stripes.length > 0)
      per.textContent = fmt(stripes[0].month) + ' → ' + fmt(stripes[stripes.length-1].month);
  }

  // ── STRIPES ──────────────────────────────────────────────────────────
  function renderStripes() {
    const canvas = document.getElementById('canvas-stripes');
    if (!canvas) return;

    const W = canvas.parentElement.clientWidth || 400;
    const H = 44;
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');

    if (!stripes.length) {
      ctx.fillStyle = '#252522';
      ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = C.t3;
      ctx.font = '10px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('Aucune donnée', W/2, H/2 + 4);
      return;
    }

    const sw = W / stripes.length;
    stripes.forEach((s, i) => {
      ctx.fillStyle   = s.hasData ? s.color : '#252522';
      ctx.globalAlpha = s.hasData ? 1 : 0.55;
      ctx.fillRect(Math.floor(i * sw), 0, Math.ceil(sw) + 1, H);
      ctx.globalAlpha = 1;
    });

    // Axe
    const ax = document.getElementById('stripes-axis');
    if (ax) {
      ax.innerHTML = '';
      const MO = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
      stripes.forEach((s, i) => {
        if (i % 2 !== 0) return;
        const [yr, mo] = s.month.split('-').map(Number);
        const el = document.createElement('span');
        el.textContent = MO[mo-1] + ' ' + String(yr).slice(2);
        el.style.cssText = `flex:0 0 ${sw*2}px;overflow:hidden;white-space:nowrap;`;
        ax.appendChild(el);
      });
    }

    // Légende
    const lc = document.getElementById('canvas-legend');
    if (lc) {
      const lctx = lc.getContext('2d');
      const g = lctx.createLinearGradient(0, 0, 110, 0);
      [[0,'#E1F5EE'],[0.1,'#9FE1CB'],[0.2,'#5DCAA5'],[0.3,'#1D9E75'],
       [0.4,'#EF9F27'],[0.55,'#D85A30'],[0.7,'#993C1D'],[1,'#712B13']]
      .forEach(([t,c]) => g.addColorStop(t, c));
      lctx.fillStyle = g;
      lctx.fillRect(0, 0, 110, 7);
    }
  }

  // ── VECTEUR ──────────────────────────────────────────────────────────
  function renderVector() {
    const canvas = document.getElementById('canvas-vector');
    if (!canvas) return;

    const S = 140;
    canvas.width = canvas.height = S;
    const ctx = canvas.getContext('2d');
    const cx = S/2, cy = S/2, R = S/2 - 10;

    ctx.clearRect(0, 0, S, S);

    // Cercles
    [0.33, 0.66, 1].forEach(t => {
      ctx.beginPath();
      ctx.arc(cx, cy, R*t, 0, Math.PI*2);
      ctx.setLineDash(t < 1 ? [2,3] : []);
      ctx.strokeStyle = C.grid;
      ctx.lineWidth = 1;
      ctx.stroke();
    });
    ctx.setLineDash([]);

    // Axes
    ctx.beginPath();
    ctx.moveTo(cx, cy-R); ctx.lineTo(cx, cy+R);
    ctx.moveTo(cx-R, cy); ctx.lineTo(cx+R, cy);
    ctx.strokeStyle = C.axis;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Labels canvas
    const fs = 7;
    ctx.fillStyle = C.t2;
    ctx.font = `${fs}px "IBM Plex Mono", monospace`;
    ctx.textAlign = 'center';
    ctx.fillText('↑ Inst.', cx, cy - R - 2);
    ctx.fillText('↓ Inst.', cx, cy + R + fs + 1);
    ctx.textAlign = 'right';
    ctx.fillText('Non-fasc.', cx - 3, cy - 2);
    ctx.textAlign = 'left';
    ctx.fillText('Fasc.', cx + 3, cy - 2);

    // Flèche
    if (vector.hasCurrent || vector.hasPrevious) {
      const len   = Math.min(vector.force, 1) * R * 0.84;
      const angle = Math.atan2(vector.deltaInst, vector.deltaRhet);
      const dx =  Math.cos(angle) * len;
      const dy = -Math.sin(angle) * len;
      const w  = Math.max(2, 1.5 + Math.min(vector.nActive, 10) * 0.6);

      ctx.beginPath();
      ctx.moveTo(cx, cy); ctx.lineTo(cx+dx, cy+dy);
      ctx.strokeStyle = vector.color;
      ctx.lineWidth = w;
      ctx.lineCap = 'round';
      ctx.stroke();

      const HL = Math.max(6, w * 2.2), HA = 0.44;
      ctx.lineWidth = Math.max(1.5, w * 0.7);
      ctx.beginPath();
      ctx.moveTo(cx+dx, cy+dy);
      ctx.lineTo(cx+dx - HL*Math.cos(angle-HA), cy+dy + HL*Math.sin(angle-HA));
      ctx.moveTo(cx+dx, cy+dy);
      ctx.lineTo(cx+dx - HL*Math.cos(angle+HA), cy+dy + HL*Math.sin(angle+HA));
      ctx.stroke();
    } else {
      ctx.beginPath(); ctx.arc(cx, cy, 2.5, 0, Math.PI*2);
      ctx.fillStyle = C.t3; ctx.fill();
    }

    const fe = document.getElementById('vector-force');
    const de = document.getElementById('vector-deriv');
    if (fe) { fe.textContent = pct(vector.force); fe.style.color = vector.color || C.t2; }
    if (de) {
      const d = (vector.deltaInst + vector.deltaRhet) / 2;
      de.textContent = signed(d);
      de.style.color = d > 0 ? COLORS.coral : d < 0 ? COLORS.tealDark : C.t2;
    }
  }

  // ── CRITÈRES ─────────────────────────────────────────────────────────
  function buildCritList(items, elId) {
    const listEl = document.getElementById(elId);
    if (!listEl) return;
    listEl.innerHTML = '';

    if (!items.length) {
      const e = document.createElement('div');
      e.className = 'crit-empty';
      e.textContent = 'Données insuffisantes.';
      listEl.appendChild(e);
      return;
    }

    items.forEach(({ id, curr, prev, delta, color, insuffisant }) => {
      const row = document.createElement('div');
      row.className = 'crit-row';
      row.setAttribute('role', 'listitem');
      row.setAttribute('aria-label',
        `${id} — ${LABELS[id]||id}. Courant : ${curr !== null ? pct(curr) : 'N/A'}${delta !== null ? ', variation : '+signed(delta) : ''}`
      );

      const idEl = document.createElement('span');
      idEl.className = 'crit-row__id';
      idEl.textContent = id;
      idEl.setAttribute('aria-hidden', 'true');
      row.appendChild(idEl);

      const barsEl = document.createElement('div');
      barsEl.className = 'crit-row__bars';
      barsEl.title = LABELS[id] || id;
      barsEl.setAttribute('aria-hidden', 'true');

      if (!insuffisant && curr !== null) {
        if (prev !== null) {
          const bp = document.createElement('div');
          bp.className = 'crit-bar crit-bar--prev';
          bp.style.cssText = `width:${Math.round(prev*100)}%;background:${color}`;
          barsEl.appendChild(bp);
        }
        const bc = document.createElement('div');
        bc.className = 'crit-bar crit-bar--curr';
        bc.style.cssText = `width:${Math.round(curr*100)}%;background:${color}`;
        barsEl.appendChild(bc);
      }
      row.appendChild(barsEl);

      const dEl = document.createElement('span');
      dEl.className = 'crit-row__delta';
      dEl.setAttribute('aria-hidden', 'true');
      dEl.textContent = delta !== null ? signed(delta) : '—';
      dEl.style.color = delta !== null ? color : C.t3;
      row.appendChild(dEl);

      listEl.appendChild(row);
    });
  }

  function renderCriteres() {
    const a = criteres.filter(c => ['C-03','C-04','C-05','C-06','C-07'].includes(c.id));
    const b = criteres.filter(c => ['C-08','C-09','C-10','C-11','C-12'].includes(c.id));
    buildCritList(a, 'criteres-list-a');
    buildCritList(b, 'criteres-list-b');
  }

  // ── INIT & RESIZE ────────────────────────────────────────────────────
  function render() { renderCards(); renderStripes(); renderVector(); renderCriteres(); }
  render();
  let rt;
  window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(render, 100); });

  // ══════════════════════════════════════════════════════════════════════
  // PANEL (inchangé)
  // ══════════════════════════════════════════════════════════════════════

  const SIGNAL_MAP = {
    critique: { barColor:'#5a0000', textColor:'var(--signal-crit)', cls:'signal-crit', label:'Critique' },
    fort:     { barColor:'#7a1500', textColor:'var(--signal-high)', cls:'signal-fort', label:'Fort' },
    'modéré': { barColor:'#8a3a00', textColor:'var(--signal-mid)',  cls:'signal-modere', label:'Modéré' },
    faible:   { barColor:'#7a6200', textColor:'var(--signal-low)',  cls:'signal-faible', label:'Faible' },
    aucun:    { barColor:'#2d5a27', textColor:'var(--signal-none)', cls:'signal-none', label:'Aucun' },
  };
  const getSignal = s => SIGNAL_MAP[s] || SIGNAL_MAP['aucun'];
  function esc(s) { return s ? String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }
  function typeLabel(t) { return ({loi:'Loi',ordonnance:'Ordonnance',decret:'Décret',proposition_de_loi:'Proposition de loi',programme_electoral:'Programme électoral'})[t]||t||'—'; }
  function dateStr(d) { return d ? new Date(d).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'}) : '—'; }
  function scoreBar(p, color) { return `<div style="display:flex;align-items:center;gap:.75rem;flex:1"><div style="flex:1;height:4px;background:var(--rule);border-radius:2px;overflow:hidden"><div style="width:${p}%;height:100%;background:${color};border-radius:2px;transition:width .6s"></div></div></div>`; }

  function buildPanel(f) {
    const sig = f.scoring?.position_frise?.signal||'aucun', s = getSignal(sig);
    const sp = Math.round((f.scoring?.score_total||0)*100);
    let h = `<div class="panel-signal-bar" style="background:${s.barColor}"></div>
      <div class="panel-meta-row"><span class="label" style="color:var(--ink-faint)">${esc(typeLabel(f.source?.type))}</span><span class="label" style="color:var(--ink-faint)">${esc(dateStr(f.date_analyse))}</span><span class="signal ${s.cls}">${s.label}</span></div>
      <h2 class="panel-title">${esc(f.source?.reference||'—')}</h2>
      <p class="panel-sub">${f.source?.institution?esc(f.source.institution)+' — ':''}${f.source?.date_publication?esc(f.source.date_publication):''}</p>
      <div class="panel-score-block"><div class="panel-score-big" style="color:${s.textColor}">${sp}%</div><div class="panel-score-detail">Phase ${f.scoring?.phase_principale||f.scoring?.position_frise?.phase||'—'}<br>${f.scoring?.points_obtenus||0} pts / ${f.scoring?.criteres_applicables||0} critères applicables<br>${f.scoring?.calcul?esc(f.scoring.calcul):''}</div>${scoreBar(sp,s.barColor)}</div>`;
    h += `<div class="panel-section"><p class="panel-section-title">Contexte &amp; parties prenantes</p>`;
    if (f.source?.url_source) h+=`<p style="margin-bottom:.75rem"><a class="panel-source-link" href="${esc(f.source.url_source)}" target="_blank" rel="noopener">Texte officiel ↗</a></p>`;
    if (f.contexte_procedural?.note) h+=`<p class="contexte-text" style="margin-bottom:1rem">${esc(f.contexte_procedural.note)}</p>`;
    if (f.auteurs?.length){h+=`<div class="panel-parties">`;for(const a of f.auteurs)h+=`<div class="panel-party"><span class="panel-party-nom">${esc(a.nom)}</span><span class="panel-party-role">${esc(a.fonction)}${a.role?' — '+esc(a.role):''}</span></div>`;h+=`</div>`;}
    if (f.vote)h+=`<div style="margin-top:.75rem;padding:.6rem .75rem;background:var(--paper-dark);border-radius:2px;font-family:var(--mono);font-size:.7rem;color:var(--ink-faint)">Vote : <strong style="color:var(--ink)">${f.vote.pour||0}</strong> pour · <strong style="color:var(--ink)">${f.vote.contre||0}</strong> contre · ${f.vote.abstentions||0} abstentions${f.vote.note?'<br><span style="margin-top:.3rem;display:block">'+esc(f.vote.note)+'</span>':''}</div>`;
    h+=`</div>`;
    for(const[key,lbl,cls]of[['arguments_favorables','Arguments favorables','arg-fav'],['arguments_defavorables','Arguments défavorables','arg-def']]){const args=f[key]?.arguments||[];if(!args.length)continue;const ag=key==='arguments_favorables'?'agent 2':'agent 3';h+=`<div class="panel-section"><p class="panel-section-title">${lbl} <span style="font-style:italic;font-weight:400">(${ag})</span></p><div class="arg-list">`;for(const a of args)h+=`<div class="arg-item ${cls}"><p class="arg-titre">${esc(a.titre)}</p><p class="arg-corps">${esc(a.corps)}</p>${a.sources_citees?.length?`<div class="arg-sources">${a.sources_citees.map(s=>`<span class="arg-source-tag">${esc(s)}</span>`).join('')}</div>`:''}</div>`;h+=`</div></div>`;}
    const cl=f.scoring?.criteres||[];if(cl.length){h+=`<div class="panel-section"><p class="panel-section-title">Pondération — critères applicables <span style="font-style:italic;font-weight:400">(agent 4)</span></p>`;if(f.scoring?.note_agent)h+=`<p style="font-family:var(--serif);font-size:.82rem;color:var(--ink-light);line-height:1.6;margin-bottom:1rem;padding:.6rem .75rem;background:var(--paper-dark);border-radius:2px;border-left:2px solid var(--rule)">${esc(f.scoring.note_agent)}</p>`;h+=`<div class="critere-detail-list">`;for(const c of[...cl.filter(c=>c.applicable),...cl.filter(c=>!c.applicable)]){const[badge,bc]=!c.applicable?['N/A','badge-na']:c.score>=1?['1.0','badge-full']:c.score>0?['0.5','badge-half']:['0','badge-none'];h+=`<div class="critere-row" style="${!c.applicable?'opacity:.45':''}"><span class="critere-id">${esc(c.id)}</span><span class="critere-justif">${esc(c.justification||'—')}</span><span class="critere-score-badge ${bc}">${badge}</span></div>`;}h+=`</div></div>`;}
    h+=`<div style="display:flex;flex-direction:column;gap:.75rem;margin-top:.5rem">`;
    if(f.symetrie?.statut==='planifiee')h+=`<span class="symetrie-notice">⟳ Analyse symétrique planifiée avant ${esc(f.symetrie?.date_limite||'')}</span>`;
    else if(f.symetrie?.statut==='complete')h+=`<span class="symetrie-notice">✓ Analyse symétrique complète</span>`;
    if(f.source?.url_source)h+=`<a class="panel-source-link" href="${esc(f.source.url_source)}" target="_blank" rel="noopener">Consulter le texte officiel ↗</a>`;
    h+=`</div>`;
    return h;
  }

  const panel=document.getElementById('fiche-panel'), backdrop=document.getElementById('fiche-backdrop'),
        closeBtn=document.getElementById('fiche-close'), content=document.getElementById('fiche-content');
  let pf=null;

  function openPanel(fiche){pf=document.activeElement;content.innerHTML=buildPanel(fiche);panel.removeAttribute('hidden');backdrop.classList.add('is-open');requestAnimationFrame(()=>requestAnimationFrame(()=>{panel.classList.add('is-open');backdrop.classList.add('is-visible');}));content.scrollTop=0;closeBtn.focus();document.body.style.overflow='hidden';}
  function closePanel(){panel.classList.remove('is-open');backdrop.classList.remove('is-visible');document.body.style.overflow='';panel.addEventListener('transitionend',()=>{panel.setAttribute('hidden','');backdrop.classList.remove('is-open');content.innerHTML='';if(pf)pf.focus();},{once:true});}

  closeBtn.addEventListener('click',closePanel);
  backdrop.addEventListener('click',closePanel);
  document.addEventListener('keydown',e=>{if(e.key==='Escape'&&panel.classList.contains('is-open'))closePanel();});
  document.querySelectorAll('[data-fiche]').forEach(card=>{
    const open=()=>{try{openPanel(JSON.parse(card.getAttribute('data-fiche')));}catch(e){}};
    card.addEventListener('click',open);
    card.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();open();}});
  });

</script>
