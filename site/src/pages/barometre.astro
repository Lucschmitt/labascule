---
import Base from '../layouts/Base.astro';
import FicheCard from '../components/FicheCard.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import { computeDashboard, CRITERES_C_LABELS, COLORS } from '../lib/dashboard.js';

let fiches = [];
let etalons = [];

try {
  const fichesDir = join(process.cwd(), 'public', 'fiches');
  const files = await readdir(fichesDir).catch(() => []);
  const jsonFiles = files.filter(f => f.endsWith('.json'));

  const allFiches = await Promise.all(
    jsonFiles.map(async f => {
      const raw = await readFile(join(fichesDir, f), 'utf-8');
      return JSON.parse(raw);
    })
  );

  fiches = allFiches
    .filter(f => f.statut !== 'calibration-historique')
    .sort((a, b) => new Date(b.date_analyse) - new Date(a.date_analyse));

  etalons = allFiches
    .filter(f => f.statut === 'calibration-historique')
    .sort((a, b) => (b.scoring?.score_total || 0) - (a.scoring?.score_total || 0));
} catch (e) {}

// ── Tableau de bord longitudinal ─────────────────────────────────────────
let stripes  = [];
let vector   = { deltaInst: 0, deltaRhet: 0, force: 0, nActive: 0, color: '#1D9E75', hasCurrent: false, hasPrevious: false, angle: 0 };
let criteres = [];
let metrics  = { avgL: null, avgC: null, signal: 'Vert', signalSub: 'Aucun signal détecté', signalColor: '#1D9E75', nFiches: 0 };

try {
  const fichesDir = join(process.cwd(), 'public', 'fiches');
  const allFiles = await readdir(fichesDir, { recursive: true }).catch(() => []);
  const jsonFiles = allFiles.filter(f => f.endsWith('.json') && !f.includes('calibration'));

  const fichesDB = (
    await Promise.all(
      jsonFiles.map(async f => {
        try {
          const raw = await readFile(join(fichesDir, f), 'utf-8');
          return JSON.parse(raw);
        } catch { return null; }
      })
    )
  ).filter(Boolean).filter(f => f.statut !== 'calibration-historique');

  ({ stripes, vector, criteres, metrics } = computeDashboard(fichesDB));
} catch (e) {}

const stripesJson  = JSON.stringify(stripes);
const vectorJson   = JSON.stringify(vector);
const criteresJson = JSON.stringify(criteres);
const metricsJson  = JSON.stringify(metrics);
const labelsJson   = JSON.stringify(CRITERES_C_LABELS);
const colorsJson   = JSON.stringify(COLORS);

function signalClass(signal) {
  const map = { 'critique': 'signal-crit', 'fort': 'signal-fort', 'modéré': 'signal-modere', 'faible': 'signal-faible', 'aucun': 'signal-none' };
  return map[signal] || 'signal-none';
}
---

<Base
  title="Baromètre législatif"
  description="Baromètre des textes législatifs français analysés selon la grille de similitude structurelle avec les séquences historiques de bascule autoritaire."
>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- HERO DASHBOARD — fond sombre, occupe un écran                        -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<div class="hero" id="hero">

  <header class="hero__header">
    <div class="hero__brand">
      <span class="hero__brand-name">Observatoire La Bascule</span>
      <span class="hero__brand-tag">prototype v0.2</span>
    </div>
    <div class="hero__period">
      <span class="hero__period-label">Fenêtre active</span>
      <span class="hero__period-value" id="hero-period-value">—</span>
    </div>
  </header>

  <!-- Cards métriques -->
  <div class="hero__cards">
    <div class="hcard">
      <span class="hcard__label">Score L moyen <span class="hcard__sub">(3 mois)</span></span>
      <span class="hcard__value" id="card-avgL">—</span>
      <span class="hcard__detail">sous-grille législative</span>
    </div>
    <div class="hcard">
      <span class="hcard__label">Score C moyen <span class="hcard__sub">(3 mois)</span></span>
      <span class="hcard__value" id="card-avgC">—</span>
      <span class="hcard__detail">sous-grille contextuelle</span>
    </div>
    <div class="hcard hcard--signal" id="card-signal">
      <span class="hcard__label">Signal période</span>
      <span class="hcard__value" id="card-signal-value">—</span>
      <span class="hcard__detail" id="card-signal-sub"></span>
    </div>
  </div>

  <!-- Zone viz : stripes (haut) + vecteur/critères (bas) -->
  <div class="hero__viz-top">
    <p class="hero__viz-title">INTENSITÉ MENSUELLE — SCORE L NORMALISÉ</p>
    <div class="stripes-wrap">
      <canvas id="canvas-stripes" height="60" aria-label="Stripes mensuelles"></canvas>
      <div class="stripes-axis" id="stripes-axis"></div>
    </div>
    <div class="stripes-legend-row">
      <canvas id="canvas-legend" width="120" height="10" aria-hidden="true"></canvas>
      <div class="stripes-legend-labels">
        <span>Aucun signal</span>
        <span>Signal critique</span>
      </div>
      <p class="stripes-legend-note">
        Score L normalisé 0 → 1 · Plus la bande est foncée, plus les critères législatifs sont activés
      </p>
    </div>
  </div>

  <div class="hero__viz-bottom">

    <!-- Vecteur -->
    <div class="hero__vector-block">
      <p class="hero__viz-title">VECTEUR DE PROGRESSION (DÉRIVÉE 3 MOIS)</p>
      <div class="vector-inner">
        <canvas id="canvas-vector" width="160" height="160" aria-label="Vecteur de progression autoritaire"></canvas>
        <div class="vector-metrics">
          <div class="vmetric">
            <span class="vmetric__label">Force du signal</span>
            <span class="vmetric__value" id="vector-force">—</span>
          </div>
          <div class="vmetric">
            <span class="vmetric__label">Dérivée 3 mois</span>
            <span class="vmetric__value" id="vector-deriv">—</span>
          </div>
        </div>
      </div>
      <p class="hero__viz-ref">
        Axe vertical : diffusion institutionnelle (Paxton 2004)<br>
        Axe horizontal : intensification rhétorique (Levitsky &amp; Ziblatt 2018)<br>
        Épaisseur = nombre de critères C activés
      </p>
    </div>

    <!-- Critères C -->
    <div class="hero__criteres-block">
      <p class="hero__viz-title">CRITÈRES C — OCCURRENCE SUR 6 MOIS</p>
      <div class="criteres-header">
        <span class="criteres-header__id">Critère</span>
        <span class="criteres-header__bar">M-6 → M actuel · Δ</span>
      </div>
      <div class="criteres-list" id="criteres-list" role="list">
        <div class="criteres-empty">Chargement…</div>
      </div>
      <p class="hero__viz-ref">
        Barre foncée = période actuelle · Barre claire = 6 mois avant<br>
        Fenêtre 6 mois : seuil canonique pour distinguer tendance structurelle du bruit conjoncturel (CDC/ECDC ; Levitsky &amp; Ziblatt 2018, pp. 91-108)
      </p>
    </div>

  </div>
</div><!-- /hero -->

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- CONTENU : fiches + étalons                                           -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<div class="content-zone">

  <div class="page-header">
    <p class="label">Baromètre législatif</p>
    <h1>Analyses en cours</h1>
    <p class="lead">
      Chaque texte est analysé par un pipeline de 4 agents IA indépendants
      selon la grille de 17 critères académiques.
      Les scores mesurent des <strong>similitudes de mécanisme</strong> avec les
      séquences historiques de référence — non une qualification politique des auteurs.
    </p>
  </div>

  <hr class="divider" />

  <div class="dashboard">
    <div class="dash-item">
      <span class="dash-value">{fiches.length}</span>
      <span class="label">Fiches publiées</span>
    </div>
    <div class="dash-item">
      <span class="dash-value">{fiches.filter(f => f.symetrie?.statut === 'planifiee').length}</span>
      <span class="label">Analyses symétriques en cours</span>
    </div>
    <div class="dash-item">
      <span class="dash-value">v0.1.0</span>
      <span class="label">Version de la grille</span>
    </div>
  </div>

  <hr class="divider" />

  <h2>Textes contemporains</h2>
  <div class="fiches-grid">
    {fiches.map(fiche => <FicheCard fiche={fiche} />)}
  </div>
  {fiches.length === 0 && (
    <p class="empty-state">
      Aucune fiche publiée — copiez les fichiers JSON dans <code>public/fiches/</code>
    </p>
  )}

  <hr class="divider" />

  <h2>Étalons de calibration</h2>
  <p class="lead" style="font-size: 0.9rem; margin-bottom: 1.5rem;">
    Ces textes historiques servent à valider la grille.
    Un score de 100% est attendu sur les textes fondateurs de la dictature.
  </p>
  <div class="etalons-list">
    {etalons.map(fiche => (
      <div class="etalon-row">
        <div class="etalon-meta">
          <span class={`signal ${signalClass(fiche.scoring?.position_frise?.signal)}`}>
            {fiche.scoring?.position_frise?.signal || '—'}
          </span>
          <span class="etalon-ref">{fiche.source?.reference?.substring(0, 80)}</span>
        </div>
        <div class="score-bar-wrap" style="max-width: 280px;">
          <div class="score-bar">
            <div class="score-bar-fill" style={`width: ${(fiche.scoring?.score_total || 0) * 100}%; background: var(--signal-crit)`}></div>
          </div>
          <span class="score-value" style="color: var(--signal-crit)">
            {Math.round((fiche.scoring?.score_total || 0) * 100)}%
          </span>
        </div>
      </div>
    ))}
  </div>

  <hr class="divider" />

  <div class="method-note">
    <p class="label">Note méthodologique</p>
    <p>
      Les critères C-03, C-04, C-05, C-06, C-07 sont des critères contextuels
      non évaluables sur un texte législatif isolé. Les scores reflètent les critères
      applicables au texte analysé. <a href={`${import.meta.env.BASE_URL}/methode`}>Lire la méthode →</a>
    </p>
  </div>

</div><!-- /content-zone -->

</Base>

<!-- Backdrop + Panel (inchangés) -->
<div id="fiche-backdrop" class="fiche-backdrop" aria-hidden="true"></div>
<aside id="fiche-panel" class="fiche-panel" role="dialog" aria-modal="true" aria-label="Détail de la fiche" hidden>
  <div class="panel-inner">
    <button id="fiche-close" class="panel-close" aria-label="Fermer">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <line x1="2" y1="2" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="2" x2="2" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div id="fiche-content" class="panel-content"></div>
  </div>
</aside>

<style>
/* ══════════════════════════════════════════════════════════════════════════
   HERO — fond sombre, hauteur 100vh
   ══════════════════════════════════════════════════════════════════════════ */

.hero {
  background: #0d0d0b;
  color: #ddd9d0;
  /* Cassement du padding du layout parent — adapter si la valeur diffère */
  margin: -2rem -2rem 0;
  width: calc(100% + 4rem);
  box-sizing: border-box;
  padding: 1.5rem 2rem 1.5rem;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* En-tête */
.hero__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero__brand { display: flex; align-items: baseline; gap: 0.75rem; }
.hero__brand-name { font-size: 1.05rem; font-weight: 600; letter-spacing: -0.01em; color: #f0ece2; }
.hero__brand-tag  { font-size: 0.72rem; color: #555; }

.hero__period { display: flex; flex-direction: column; align-items: flex-end; gap: 0.1rem; }
.hero__period-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: #444; }
.hero__period-value { font-size: 0.75rem; color: #666; font-variant-numeric: tabular-nums; }

/* Cards */
.hero__cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.6rem;
}

.hcard {
  background: #151513;
  border: 1px solid #252522;
  border-radius: 5px;
  padding: 0.75rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.hcard--signal { border-left-width: 3px; }

.hcard__label  { font-size: 0.7rem; color: #777; letter-spacing: 0.02em; }
.hcard__sub    { color: #4a4a48; font-size: 0.85em; }
.hcard__value  { font-size: 2rem; font-weight: 500; line-height: 1; color: #f0ece2; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
.hcard__detail { font-size: 0.67rem; color: #4a4a48; margin-top: 0.05rem; }

/* Viz titre + ref partagés */
.hero__viz-title {
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #555;
  margin-bottom: 0.5rem;
}

.hero__viz-ref {
  font-size: 0.66rem;
  color: #3d3d3b;
  line-height: 1.5;
  margin-top: 0.5rem;
}

/* Stripes (rangée du haut) */
.hero__viz-top { display: flex; flex-direction: column; }

.stripes-wrap { }

#canvas-stripes {
  display: block;
  width: 100%;
  border-radius: 3px;
}

.stripes-axis {
  display: flex;
  font-size: 0.62rem;
  color: #4a4a48;
  margin-top: 4px;
  font-variant-numeric: tabular-nums;
}

.stripes-legend-row {
  margin-top: 0.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

#canvas-legend { border-radius: 2px; flex-shrink: 0; }

.stripes-legend-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.62rem;
  color: #4a4a48;
  width: 120px;
}

.stripes-legend-note {
  font-size: 0.66rem;
  color: #3d3d3b;
  margin: 0;
  line-height: 1.45;
}

/* Viz bas : vecteur + critères côte à côte */
.hero__viz-bottom {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.5rem;
  flex: 1;
  min-height: 0;
}

/* Vecteur */
.hero__vector-block { display: flex; flex-direction: column; }

.vector-inner {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

#canvas-vector { width: 160px; height: 160px; flex-shrink: 0; }

.vector-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.4rem;
}

.vmetric {
  background: #151513;
  border: 1px solid #252522;
  border-radius: 4px;
  padding: 0.45rem 0.6rem;
  display: flex;
  flex-direction: column;
  gap: 0.08rem;
}

.vmetric__label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: #4a4a48; }
.vmetric__value { font-size: 1.15rem; font-weight: 500; color: #f0ece2; font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }

/* Critères */
.hero__criteres-block { display: flex; flex-direction: column; min-width: 0; }

.criteres-header {
  display: flex;
  gap: 0.5rem;
  font-size: 0.6rem;
  color: #444;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.35rem;
  padding-bottom: 0.25rem;
  border-bottom: 1px solid #1c1c1a;
}

.criteres-header__id  { width: 3rem; flex-shrink: 0; }
.criteres-header__bar { flex: 1; }

.criteres-list { display: flex; flex-direction: column; gap: 0.28rem; }

.critere-row { display: flex; align-items: center; gap: 0.5rem; }

.critere-row__id {
  font-size: 0.66rem;
  font-weight: 500;
  width: 3rem;
  flex-shrink: 0;
  color: #5a5a58;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
}

.critere-row__bars {
  position: relative;
  flex: 1;
  height: 13px;
  border-radius: 2px;
  background: #181816;
  cursor: help;
  overflow: hidden;
}

.critere-bar { position: absolute; top: 0; left: 0; height: 100%; border-radius: 2px; }
.critere-bar--prev { opacity: 0.25; }

.critere-row__delta {
  font-size: 0.66rem;
  font-weight: 600;
  width: 3.25rem;
  text-align: right;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

.criteres-empty { color: #3d3d3b; font-style: italic; font-size: 0.78rem; }

/* ══════════════════════════════════════════════════════════════════════════
   CONTENT ZONE — fond clair
   ══════════════════════════════════════════════════════════════════════════ */

.content-zone { padding-top: 2.5rem; }

.page-header { margin-bottom: 1rem; }

.dashboard { display: flex; gap: 2rem; flex-wrap: wrap; margin: 1.5rem 0; }
.dash-item { display: flex; flex-direction: column; gap: 0.2rem; }
.dash-value { font-family: var(--mono); font-size: 1.8rem; font-weight: 500; color: var(--ink); line-height: 1; }

.fiches-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1rem; }

.empty-state { color: var(--ink-faint); font-size: 0.9rem; padding: 2rem; text-align: center; border: 1px dashed var(--rule); border-radius: 4px; }

.etalons-list { display: flex; flex-direction: column; gap: 0.75rem; }

.etalon-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1rem; background: var(--paper-dark); border-radius: 2px; flex-wrap: wrap; }
.etalon-meta { display: flex; align-items: center; gap: 0.75rem; min-width: 0; }
.etalon-ref { font-size: 0.85rem; color: var(--ink-light); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; }

.method-note { font-size: 0.85rem; color: var(--ink-faint); background: var(--paper-dark); padding: 1rem 1.25rem; border-radius: 2px; }
.method-note .label { margin-bottom: 0.4rem; }
.method-note a { color: var(--ink-light); }

/* ══════════════════════════════════════════════════════════════════════════
   PANEL
   ══════════════════════════════════════════════════════════════════════════ */

.fiche-backdrop { display: none; position: fixed; inset: 0; background: rgba(26, 24, 20, 0.35); backdrop-filter: blur(2px); z-index: 200; opacity: 0; transition: opacity 0.25s ease; }
.fiche-backdrop.is-open { display: block; }
.fiche-backdrop.is-visible { opacity: 1; }

.fiche-panel { position: fixed; top: 0; right: 0; bottom: 0; width: min(560px, 100vw); background: var(--paper); border-left: 2px solid var(--ink); z-index: 201; transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; overflow: hidden; }
.fiche-panel:not([hidden]) { display: flex; }
.fiche-panel.is-open { transform: translateX(0); }

.panel-inner { display: flex; flex-direction: column; height: 100%; position: relative; }
.panel-close { position: absolute; top: 1.25rem; right: 1.25rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--paper-dark); border: 1px solid var(--rule); border-radius: 2px; color: var(--ink-light); cursor: pointer; transition: color 0.15s, border-color 0.15s; z-index: 10; }
.panel-close:hover { color: var(--ink); border-color: var(--ink-faint); }
.panel-content { flex: 1; overflow-y: auto; padding: 2rem 2rem 3rem; scroll-behavior: smooth; }

:global(.panel-signal-bar) { height: 4px; border-radius: 2px; margin-bottom: 1.5rem; margin-left: -2rem; margin-right: -2rem; margin-top: -2rem; }
:global(.panel-meta-row) { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
:global(.panel-title) { font-family: var(--display); font-size: 1.3rem; font-weight: 700; line-height: 1.3; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 0.5rem; }
:global(.panel-sub) { font-family: var(--mono); font-size: 0.7rem; color: var(--ink-faint); letter-spacing: 0.06em; margin-bottom: 1.5rem; }
:global(.panel-score-block) { background: var(--paper-dark); border: 1px solid var(--rule); border-radius: 2px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1.5rem; }
:global(.panel-score-big) { font-family: var(--mono); font-size: 2.4rem; font-weight: 500; line-height: 1; min-width: 4.5rem; }
:global(.panel-score-detail) { font-family: var(--mono); font-size: 0.7rem; color: var(--ink-faint); line-height: 1.6; letter-spacing: 0.03em; }
:global(.panel-section) { margin-bottom: 1.75rem; }
:global(.panel-section-title) { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); border-bottom: 1px solid var(--rule); padding-bottom: 0.4rem; margin-bottom: 1rem; }
:global(.panel-parties) { display: flex; flex-direction: column; gap: 0.5rem; }
:global(.panel-party) { display: flex; gap: 0.75rem; padding: 0.6rem 0.75rem; background: var(--paper-dark); border-radius: 2px; font-size: 0.85rem; }
:global(.panel-party-nom) { font-weight: 400; color: var(--ink); min-width: 7rem; }
:global(.panel-party-role) { color: var(--ink-faint); font-size: 0.78rem; line-height: 1.4; }
:global(.contexte-text) { font-family: var(--serif); font-size: 0.85rem; color: var(--ink-light); line-height: 1.65; }
:global(.arg-list) { display: flex; flex-direction: column; gap: 0.85rem; }
:global(.arg-item) { border-left: 3px solid transparent; padding: 0.75rem 0.9rem; background: var(--paper-dark); border-radius: 0 2px 2px 0; }
:global(.arg-item.arg-fav) { border-left-color: var(--signal-none); }
:global(.arg-item.arg-def) { border-left-color: var(--signal-crit); }
:global(.arg-titre) { font-family: var(--serif); font-size: 0.88rem; font-weight: 400; color: var(--ink); margin-bottom: 0.4rem; }
:global(.arg-corps) { font-family: var(--serif); font-size: 0.8rem; color: var(--ink-light); line-height: 1.6; margin-bottom: 0.5rem; }
:global(.arg-sources) { display: flex; flex-wrap: wrap; gap: 0.3rem; }
:global(.arg-source-tag) { font-family: var(--mono); font-size: 0.6rem; color: var(--ink-faint); background: var(--paper); border: 1px solid var(--rule); padding: 0.1rem 0.4rem; border-radius: 2px; letter-spacing: 0.03em; }
:global(.critere-detail-list) { display: flex; flex-direction: column; gap: 0.6rem; }
:global(.critere-row) { display: grid; grid-template-columns: 2.5rem 1fr auto; gap: 0.75rem; align-items: start; padding: 0.6rem 0.75rem; background: var(--paper-dark); border-radius: 2px; font-size: 0.8rem; }
:global(.critere-id) { font-family: var(--mono); font-size: 0.7rem; font-weight: 500; color: var(--ink-light); letter-spacing: 0.04em; }
:global(.critere-justif) { font-family: var(--serif); color: var(--ink-light); line-height: 1.55; font-size: 0.8rem; }
:global(.critere-score-badge) { font-family: var(--mono); font-size: 0.7rem; font-weight: 500; padding: 0.15rem 0.4rem; border-radius: 2px; white-space: nowrap; }
:global(.badge-full) { background: var(--bg-crit); color: var(--signal-crit); }
:global(.badge-half) { background: var(--bg-mid); color: var(--signal-mid); }
:global(.badge-none) { background: var(--paper); color: var(--ink-faint); border: 1px solid var(--rule); }
:global(.badge-na)   { background: var(--paper); color: var(--ink-faint); border: 1px solid var(--rule); font-style: italic; }
:global(.panel-source-link) { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.05em; color: var(--ink-light); text-decoration: none; border-bottom: 1px solid var(--rule); padding-bottom: 1px; transition: color 0.15s, border-color 0.15s; }
:global(.panel-source-link:hover) { color: var(--ink); border-color: var(--ink); }
:global(.symetrie-notice) { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--mono); font-size: 0.68rem; color: var(--ink-faint); background: var(--paper-dark); border: 1px solid var(--rule); padding: 0.35rem 0.65rem; border-radius: 2px; }

/* Responsive */
@media (max-width: 860px) {
  .hero__viz-bottom { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .hero { padding: 1rem; margin: -1rem -1rem 0; width: calc(100% + 2rem); min-height: auto; }
  .hero__cards { grid-template-columns: 1fr; }
  .fiches-grid { grid-template-columns: 1fr; }
  .fiche-panel { width: 100vw; }
  .panel-content { padding: 1.5rem 1.25rem 3rem; }
  :global(.panel-signal-bar) { margin-left: -1.25rem; margin-right: -1.25rem; }
}
</style>

<script define:vars={{ stripesJson, vectorJson, criteresJson, metricsJson, labelsJson, colorsJson }}>

  const stripes  = JSON.parse(stripesJson);
  const vector   = JSON.parse(vectorJson);
  const criteres = JSON.parse(criteresJson);
  const metrics  = JSON.parse(metricsJson);
  const LABELS   = JSON.parse(labelsJson);
  const COLORS   = JSON.parse(colorsJson);

  function signedPct(v) {
    if (v === null || v === undefined) return '—';
    const s = (v * 100).toFixed(1);
    return v >= 0 ? '+' + s + ' %' : s + ' %';
  }

  // ── CARDS ──────────────────────────────────────────────────────────────
  function renderCards() {
    const avgLEl   = document.getElementById('card-avgL');
    const avgCEl   = document.getElementById('card-avgC');
    const sigEl    = document.getElementById('card-signal');
    const sigValEl = document.getElementById('card-signal-value');
    const sigSubEl = document.getElementById('card-signal-sub');
    const periodEl = document.getElementById('hero-period-value');

    if (avgLEl) avgLEl.textContent = metrics.avgL !== null ? Math.round(metrics.avgL * 100) + '%' : '—';
    if (avgCEl) avgCEl.textContent = metrics.avgC !== null ? Math.round(metrics.avgC * 100) + '%' : '—';
    if (sigValEl) { sigValEl.textContent = metrics.signal; sigValEl.style.color = metrics.signalColor; }
    if (sigSubEl) sigSubEl.textContent = metrics.signalSub;
    if (sigEl)    sigEl.style.borderLeftColor = metrics.signalColor;

    if (periodEl && stripes.length > 0) {
      const MO = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
      const fmt = k => { const [y,m] = k.split('-').map(Number); return MO[m-1] + ' ' + y; };
      periodEl.textContent = fmt(stripes[0].month) + ' → ' + fmt(stripes[stripes.length-1].month);
    }
  }

  // ── STRIPES ────────────────────────────────────────────────────────────
  function renderStripes() {
    const canvas = document.getElementById('canvas-stripes');
    if (!canvas || stripes.length === 0) return;

    const W = canvas.parentElement.clientWidth || 600;
    const H = 60;
    canvas.width = W; canvas.height = H;

    const ctx = canvas.getContext('2d');
    const sw = W / stripes.length;

    stripes.forEach((s, i) => {
      ctx.fillStyle   = s.color;
      ctx.globalAlpha = s.hasData ? 1 : 0.18;
      ctx.fillRect(Math.floor(i * sw), 0, Math.ceil(sw) + 1, H);
      ctx.globalAlpha = 1;
    });

    const axisEl = document.getElementById('stripes-axis');
    if (axisEl) {
      axisEl.innerHTML = '';
      const MO = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
      stripes.forEach((s, i) => {
        if (i % 2 !== 0) return;
        const [yr, mo] = s.month.split('-').map(Number);
        const el = document.createElement('span');
        el.textContent = MO[mo-1] + ' ' + String(yr).slice(2);
        el.style.flex = '0 0 ' + (sw * 2) + 'px';
        el.style.overflow = 'hidden';
        el.style.whiteSpace = 'nowrap';
        axisEl.appendChild(el);
      });
    }

    const lc = document.getElementById('canvas-legend');
    if (lc) {
      const lctx = lc.getContext('2d');
      const g = lctx.createLinearGradient(0, 0, 120, 0);
      [[0,'#E1F5EE'],[0.1,'#9FE1CB'],[0.2,'#5DCAA5'],[0.3,'#1D9E75'],
       [0.4,'#EF9F27'],[0.55,'#D85A30'],[0.7,'#993C1D'],[1,'#712B13']]
      .forEach(([t,c]) => g.addColorStop(t, c));
      lctx.fillStyle = g;
      lctx.fillRect(0, 0, 120, 10);
    }
  }

  // ── VECTEUR ────────────────────────────────────────────────────────────
  function renderVector() {
    const canvas = document.getElementById('canvas-vector');
    if (!canvas) return;

    const S = 160;
    canvas.width = canvas.height = S;
    const ctx = canvas.getContext('2d');
    const cx = S/2, cy = S/2, R = S/2 - 12;

    ctx.clearRect(0, 0, S, S);

    [0.33, 0.66, 1].forEach(t => {
      ctx.beginPath();
      ctx.arc(cx, cy, R*t, 0, Math.PI*2);
      ctx.setLineDash(t < 1 ? [3,4] : []);
      ctx.strokeStyle = 'rgba(255,255,255,0.07)';
      ctx.lineWidth = 1;
      ctx.stroke();
    });
    ctx.setLineDash([]);

    ctx.beginPath();
    ctx.moveTo(cx, cy-R); ctx.lineTo(cx, cy+R);
    ctx.moveTo(cx-R, cy); ctx.lineTo(cx+R, cy);
    ctx.strokeStyle = 'rgba(255,255,255,0.17)';
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.fillStyle = '#555';
    ctx.font = '7.5px monospace';
    ctx.textAlign = 'center';
    ctx.fillText('Diffusion', cx, cy-R-9);
    ctx.fillText('institutionnelle', cx, cy-R-1);
    ctx.fillText('Intensification', cx, cy+R+9);
    ctx.fillText('rhétorique ↓', cx, cy+R+17);
    ctx.textAlign = 'right';
    ctx.fillText('Non-fasciste', cx-4, cy-3);
    ctx.textAlign = 'left';
    ctx.fillText('Fascisant', cx+4, cy-3);

    if (vector.hasCurrent || vector.hasPrevious) {
      const len   = Math.min(vector.force, 1) * R * 0.88;
      const angle = Math.atan2(vector.deltaInst, vector.deltaRhet);
      const dx =  Math.cos(angle) * len;
      const dy = -Math.sin(angle) * len;
      const w  = 2 + Math.min(vector.nActive, 10) * 0.8;

      ctx.beginPath();
      ctx.moveTo(cx, cy); ctx.lineTo(cx+dx, cy+dy);
      ctx.strokeStyle = vector.color;
      ctx.lineWidth = w;
      ctx.lineCap = 'round';
      ctx.stroke();

      const HL=8, HA=0.42;
      ctx.beginPath();
      ctx.moveTo(cx+dx, cy+dy);
      ctx.lineTo(cx+dx - HL*Math.cos(angle-HA), cy+dy + HL*Math.sin(angle-HA));
      ctx.moveTo(cx+dx, cy+dy);
      ctx.lineTo(cx+dx - HL*Math.cos(angle+HA), cy+dy + HL*Math.sin(angle+HA));
      ctx.stroke();
    }

    const fe = document.getElementById('vector-force');
    const de = document.getElementById('vector-deriv');
    if (fe) { fe.textContent = (vector.force*100).toFixed(1)+'%'; fe.style.color = vector.color; }
    if (de) {
      const d = (vector.deltaInst + vector.deltaRhet) / 2;
      de.textContent = signedPct(d);
      de.style.color = d > 0 ? COLORS.coral : COLORS.tealDark;
    }
  }

  // ── CRITÈRES ───────────────────────────────────────────────────────────
  function renderCriteres() {
    const listEl = document.getElementById('criteres-list');
    if (!listEl) return;

    if (!criteres.length) {
      listEl.innerHTML = '<div class="criteres-empty">Données insuffisantes.</div>';
      return;
    }

    listEl.innerHTML = '';
    criteres.forEach(({ id, curr, prev, delta, color, insuffisant }) => {
      const row = document.createElement('div');
      row.className = 'critere-row';
      row.setAttribute('role', 'listitem');

      const idEl = document.createElement('span');
      idEl.className = 'critere-row__id';
      idEl.textContent = id;
      row.appendChild(idEl);

      const barsEl = document.createElement('div');
      barsEl.className = 'critere-row__bars';
      barsEl.title = LABELS[id] || id;

      if (!insuffisant && curr !== null) {
        if (prev !== null) {
          const bp = document.createElement('div');
          bp.className = 'critere-bar critere-bar--prev';
          bp.style.cssText = `width:${prev*100}%;background:${color}`;
          barsEl.appendChild(bp);
        }
        const bc = document.createElement('div');
        bc.className = 'critere-bar critere-bar--curr';
        bc.style.cssText = `width:${curr*100}%;background:${color}`;
        barsEl.appendChild(bc);
      }
      row.appendChild(barsEl);

      const dEl = document.createElement('span');
      dEl.className = 'critere-row__delta';
      dEl.textContent = delta !== null ? (delta>=0?'+':'')+Math.round(delta*100)+'%' : '—';
      dEl.style.color = delta !== null ? color : '#3d3d3b';
      row.appendChild(dEl);

      listEl.appendChild(row);
    });
  }

  // ── INIT ───────────────────────────────────────────────────────────────
  function render() { renderCards(); renderStripes(); renderVector(); renderCriteres(); }
  render();
  let t;
  window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(render, 120); });

  // ══════════════════════════════════════════════════════════════════════
  // PANEL (inchangé)
  // ══════════════════════════════════════════════════════════════════════

  const SIGNAL_MAP = {
    critique: { barColor:'#5a0000', textColor:'var(--signal-crit)', cls:'signal-crit', label:'Critique' },
    fort:     { barColor:'#7a1500', textColor:'var(--signal-high)', cls:'signal-fort', label:'Fort' },
    'modéré': { barColor:'#8a3a00', textColor:'var(--signal-mid)',  cls:'signal-modere', label:'Modéré' },
    faible:   { barColor:'#7a6200', textColor:'var(--signal-low)',  cls:'signal-faible', label:'Faible' },
    aucun:    { barColor:'#2d5a27', textColor:'var(--signal-none)', cls:'signal-none', label:'Aucun' },
  };

  const getSignal = s => SIGNAL_MAP[s] || SIGNAL_MAP['aucun'];

  function esc(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function typeLabel(t) {
    return ({loi:'Loi',ordonnance:'Ordonnance',decret:'Décret',proposition_de_loi:'Proposition de loi',programme_electoral:'Programme électoral'})[t] || t || '—';
  }

  function dateStr(d) {
    if (!d) return '—';
    return new Date(d).toLocaleDateString('fr-FR', { day:'numeric', month:'long', year:'numeric' });
  }

  function scoreBar(pct, color) {
    return `<div style="display:flex;align-items:center;gap:0.75rem;flex:1;"><div style="flex:1;height:4px;background:var(--rule);border-radius:2px;overflow:hidden;"><div style="width:${pct}%;height:100%;background:${color};border-radius:2px;transition:width 0.6s;"></div></div></div>`;
  }

  function buildPanel(f) {
    const sig = f.scoring?.position_frise?.signal || 'aucun';
    const s = getSignal(sig);
    const scorePct = Math.round((f.scoring?.score_total||0)*100);

    let html = `
      <div class="panel-signal-bar" style="background:${s.barColor};margin-top:-2rem;margin-left:-2rem;margin-right:-2rem;margin-bottom:1.75rem;"></div>
      <div class="panel-meta-row">
        <span class="label" style="color:var(--ink-faint);">${esc(typeLabel(f.source?.type))}</span>
        <span class="label" style="color:var(--ink-faint);">${esc(dateStr(f.date_analyse))}</span>
        <span class="signal ${s.cls}">${s.label}</span>
      </div>
      <h2 class="panel-title">${esc(f.source?.reference||'—')}</h2>
      <p class="panel-sub">${f.source?.institution?esc(f.source.institution)+' — ':''}${f.source?.date_publication?esc(f.source.date_publication):''}</p>
      <div class="panel-score-block">
        <div class="panel-score-big" style="color:${s.textColor};">${scorePct}%</div>
        <div class="panel-score-detail">Phase ${f.scoring?.phase_principale||f.scoring?.position_frise?.phase||'—'}<br>${f.scoring?.points_obtenus||0} pts / ${f.scoring?.criteres_applicables||0} critères applicables<br>${f.scoring?.calcul?esc(f.scoring.calcul):''}</div>
        ${scoreBar(scorePct, s.barColor)}
      </div>`;

    html += `<div class="panel-section"><p class="panel-section-title">Contexte &amp; parties prenantes</p>`;
    if (f.source?.url_source) html += `<p style="margin-bottom:0.75rem;"><a class="panel-source-link" href="${esc(f.source.url_source)}" target="_blank" rel="noopener">Texte officiel ↗</a></p>`;
    if (f.contexte_procedural?.note) html += `<p class="contexte-text" style="margin-bottom:1rem;">${esc(f.contexte_procedural.note)}</p>`;
    if (f.auteurs?.length) { html+=`<div class="panel-parties">`; for (const a of f.auteurs) html+=`<div class="panel-party"><span class="panel-party-nom">${esc(a.nom)}</span><span class="panel-party-role">${esc(a.fonction)}${a.role?' — '+esc(a.role):''}</span></div>`; html+=`</div>`; }
    if (f.vote) html+=`<div style="margin-top:0.75rem;padding:0.6rem 0.75rem;background:var(--paper-dark);border-radius:2px;font-family:var(--mono);font-size:0.7rem;color:var(--ink-faint);">Vote : <strong style="color:var(--ink);">${f.vote.pour||0}</strong> pour · <strong style="color:var(--ink);">${f.vote.contre||0}</strong> contre · ${f.vote.abstentions||0} abstentions${f.vote.note?'<br><span style="margin-top:0.3rem;display:block;">'+esc(f.vote.note)+'</span>':''}</div>`;
    html += `</div>`;

    for (const [key, lbl, cls] of [['arguments_favorables','Arguments favorables','arg-fav'],['arguments_defavorables','Arguments défavorables','arg-def']]) {
      const args = f[key]?.arguments||[];
      if (!args.length) continue;
      const agent = key==='arguments_favorables'?'agent 2':'agent 3';
      html+=`<div class="panel-section"><p class="panel-section-title">${lbl} <span style="font-style:italic;font-weight:400;">(${agent})</span></p><div class="arg-list">`;
      for (const a of args) html+=`<div class="arg-item ${cls}"><p class="arg-titre">${esc(a.titre)}</p><p class="arg-corps">${esc(a.corps)}</p>${a.sources_citees?.length?`<div class="arg-sources">${a.sources_citees.map(s=>`<span class="arg-source-tag">${esc(s)}</span>`).join('')}</div>`:''}</div>`;
      html+=`</div></div>`;
    }

    const cl = f.scoring?.criteres||[];
    if (cl.length) {
      html+=`<div class="panel-section"><p class="panel-section-title">Pondération — critères applicables <span style="font-style:italic;font-weight:400;">(agent 4)</span></p>`;
      if (f.scoring?.note_agent) html+=`<p style="font-family:var(--serif);font-size:0.82rem;color:var(--ink-light);line-height:1.6;margin-bottom:1rem;padding:0.6rem 0.75rem;background:var(--paper-dark);border-radius:2px;border-left:2px solid var(--rule);">${esc(f.scoring.note_agent)}</p>`;
      html+=`<div class="critere-detail-list">`;
      for (const c of [...cl.filter(c=>c.applicable),...cl.filter(c=>!c.applicable)]) {
        const [badge,bc] = !c.applicable?['N/A','badge-na']:c.score>=1?['1.0','badge-full']:c.score>0?['0.5','badge-half']:['0','badge-none'];
        html+=`<div class="critere-row" style="${!c.applicable?'opacity:0.45;':''}"><span class="critere-id">${esc(c.id)}</span><span class="critere-justif">${esc(c.justification||'—')}</span><span class="critere-score-badge ${bc}">${badge}</span></div>`;
      }
      html+=`</div></div>`;
    }

    html+=`<div style="display:flex;flex-direction:column;gap:0.75rem;margin-top:0.5rem;">`;
    if (f.symetrie?.statut==='planifiee') html+=`<span class="symetrie-notice">⟳ Analyse symétrique planifiée avant ${esc(f.symetrie?.date_limite||'')}</span>`;
    else if (f.symetrie?.statut==='complete') html+=`<span class="symetrie-notice">✓ Analyse symétrique complète</span>`;
    if (f.source?.url_source) html+=`<a class="panel-source-link" href="${esc(f.source.url_source)}" target="_blank" rel="noopener">Consulter le texte officiel ↗</a>`;
    html+=`</div>`;

    return html;
  }

  const panel    = document.getElementById('fiche-panel');
  const backdrop = document.getElementById('fiche-backdrop');
  const closeBtn = document.getElementById('fiche-close');
  const content  = document.getElementById('fiche-content');
  let prevFocus = null;

  function openPanel(fiche) {
    prevFocus = document.activeElement;
    content.innerHTML = buildPanel(fiche);
    panel.removeAttribute('hidden');
    backdrop.classList.add('is-open');
    requestAnimationFrame(() => requestAnimationFrame(() => {
      panel.classList.add('is-open');
      backdrop.classList.add('is-visible');
    }));
    content.scrollTop = 0;
    closeBtn.focus();
    document.body.style.overflow = 'hidden';
  }

  function closePanel() {
    panel.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
    document.body.style.overflow = '';
    panel.addEventListener('transitionend', () => {
      panel.setAttribute('hidden','');
      backdrop.classList.remove('is-open');
      content.innerHTML = '';
      if (prevFocus) prevFocus.focus();
    }, { once: true });
  }

  closeBtn.addEventListener('click', closePanel);
  backdrop.addEventListener('click', closePanel);
  document.addEventListener('keydown', e => { if (e.key==='Escape' && panel.classList.contains('is-open')) closePanel(); });

  document.querySelectorAll('[data-fiche]').forEach(card => {
    const open = () => { try { openPanel(JSON.parse(card.getAttribute('data-fiche'))); } catch(e){} };
    card.addEventListener('click', open);
    card.addEventListener('keydown', e => { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); open(); } });
  });

</script>
