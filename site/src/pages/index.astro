---
import Base from '../layouts/Base.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';

// Charge la dernière fiche publiée pour le bandeau
let derniereFiche = null;
try {
  const fichesDir = join(process.cwd(), 'public', 'fiches');
  const files = await readdir(fichesDir).catch(() => []);
  const jsonFiles = files.filter(f => f.endsWith('.json'));
  const allFiches = await Promise.all(
    jsonFiles.map(async f => JSON.parse(await readFile(join(fichesDir, f), 'utf-8')))
  );
  const publiees = allFiches
    .filter(f => f.statut !== 'calibration-historique')
    .sort((a, b) => new Date(b.date_analyse) - new Date(a.date_analyse));
  derniereFiche = publiees[0] || null;
} catch {}

const scoreFrance = derniereFiche
  ? Math.round((derniereFiche.scoring?.score_total || 0) * 100)
  : null;
const signalFrance = derniereFiche?.scoring?.position_frise?.signal || null;
const signalLabel = { 'critique':'Critique','fort':'Fort','modéré':'Modéré','faible':'Faible','aucun':'Aucun signal' };
const signalCls   = { 'critique':'signal-crit','fort':'signal-fort','modéré':'signal-modere','faible':'signal-faible','aucun':'signal-none' };

const phaseActiveFrance = 3;

const phases = [
  {
    id: 0, label: "Terreau", sublabel: "Conditions structurelles",
    desc: "La crise économique et le déclassement créent un terreau fertile. Les classes moyennes se sentent abandonnées par les élites.",
    it: { year:"1919–1921", title:"Crise de l'après-guerre", details:["600 000 morts pour une 'victoire mutilée' — Fiume et Dalmatie refusées à Versailles","Inflation : le lire perd 75% de sa valeur en 4 ans","2 millions de chômeurs, occupation des usines par les ouvriers","Classes moyennes appauvries, trahies par l'État libéral"], sources:["Milza, Mussolini (Fayard, 1999)","Tasca, Naissance du fascisme (1995)"] },
    de: { year:"1919–1923", title:"Humiliation de Weimar", details:["Versailles : perte de 13% du territoire, 132 milliards de marks de réparations","Hyperinflation 1923 : 4,2 billions de marks pour 1 dollar","Putsch de Munich (1923) : Hitler incarcéré mais médiatisé","'Dolchstoßlegende' — coup de poignard dans le dos propagé par les milieux militaires"], sources:["Evans, The Coming of the Third Reich (2003)","Kershaw, Hitler 1889-1936 (1998)"] },
    fr: { year:"2015–2018", title:"Crise sociale et sentiment d'abandon", details:["Chômage > 10%, 5 millions de chômeurs en 2015","Attentats 2015-2016 : état d'urgence prolongé 2 ans","Gilets Jaunes (2018) : 300 000 manifestants, symbole du déclassement périphérique","83% des Français : 'le système profite à une petite minorité' (IPSOS 2018)"], sources:["Guilluy, La France périphérique (2014)","IPSOS, Fractures françaises (2018)"] }
  },
  {
    id: 1, label: "Émergence", sublabel: "Organisation et violence",
    desc: "Les mouvements d'extrême droite s'organisent, développent leurs milices et bénéficient du financement des élites économiques apeurées.",
    it: { year:"1919–1922", title:"Squadrisme et financement patronal", details:["Fasci di Combattimento (mars 1919) : 320 000 membres en 1921","Squadrisme : 2 000 morts politiques, 120 caméras du travail incendiées en 18 mois","Agraires du Pô financent les escouades pour briser les syndicats agricoles","Confindustria apporte son soutien dès 1921 contre le 'péril bolchevique'"], sources:["Matard-Bonucci, L'Italie fasciste (2012)","Tasca (1995)"] },
    de: { year:"1920–1932", title:"SA et financement industriel", details:["SA fondées en 1921 : 400 000 membres en 1932","Fritz Thyssen (acier), Emil Kirdorf (charbon) financent le NSDAP dès 1923","300 morts politiques lors de la campagne électorale de 1932","SS fondées en 1925, Himmler à leur tête en 1929"], sources:["Turner, German Big Business and the Rise of Hitler (1985)","Evans (2003)"] },
    fr: { year:"2017–2022", title:"Radicalisation médiatique", details:["Bolloré prend CNews (2017) : audiences ×4 en 5 ans","Zemmour : 17 condamnations pour incitation à la haine (2011-2022)","Génération Identitaire : dissoute en 2021 après 4 ans d'activité","Le Pen normalise le discours : dédiabolisation assumée depuis 2011"], sources:["Chapoutot, Les Irresponsables (2025)","Fondation Jean-Jaurès, Observatoire des radicalités (2022)"] }
  },
  {
    id: 2, label: "Légitimation", sublabel: "Progression électorale",
    desc: "Le mouvement conquiert une légitimité électorale croissante. La concentration médiatique amplifie ses thèmes dans le débat public.",
    it: { year:"1921–1922", title:"35 sièges, puis la marche", details:["Mai 1921 : 35 sièges dans la liste Giolitti — légitimité institutionnelle","Juillet 1922 : grève générale écrasée par les Chemises noires","Octobre 1922 : 300 000 fascistes convergent vers Rome","28 octobre : le Roi nomme Mussolini — refus de l'état de siège"], sources:["Milza (1999)","De Felice, Mussolini il fascista (1966)"] },
    de: { year:"1930–1932", title:"De 2,6% à 37,4%", details:["1928 : 2,6% — parti marginal","Septembre 1930 : 18,3% — 2e parti d'Allemagne après la crise de 1929","Juillet 1932 : 37,4% — 1er parti, 230 sièges","Presse Hugenberg légitime Hitler auprès des classes moyennes conservatives"], sources:["Evans (2003)","Falter, Hitlers Wähler (1991)"] },
    fr: { year:"2017–2024", title:"RN : de 8 à 143 sièges", details:["2017 : 8 sièges (2,4 millions de voix au 1er tour)","2022 : 89 sièges (6,1 millions), premier groupe d'opposition","Juin 2024 : 143 sièges (10,6 millions), 33% au 1er tour","Marine Le Pen : 41,5% au second tour présidentielle 2022"], sources:["Intérieur.gouv.fr","Chapoutot (2025)"] }
  },
  {
    id: 3, label: "Porosité", sublabel: "Ralliement du centre-droit",
    desc: "La droite traditionnelle s'allie ou s'accommode de l'extrême droite. Les mécanismes de cordon sanitaire s'effritent.",
    it: { year:"1921–1922", title:"Giolitti ouvre la porte", details:["Giolitti intègre les fascistes dans ses listes de 1921 pour 'les neutraliser'","Facta refuse de proclamer l'état de siège le 28 octobre 1922","Salandra appelle à 'intégrer les fascistes au système'","Le Roi préfère Mussolini à une guerre civile"], sources:["De Felice (1966)","Gentile, The Sacralization of Politics in Fascist Italy (1996)"] },
    de: { year:"1932–1933", title:"Papen : 'nous l'encadrerons'", details:["Von Papen convainc Hindenburg de nommer Hitler : 'nous l'encadrerons'","DNVP de Hugenberg s'allie au NSDAP dans le cabinet du 30 janvier","Cercle de Keppler : industriels organisent le financement de la transition","Hindenburg refuse la proposition Schleicher sans Hitler"], sources:["Evans (2003)","Kershaw (1998)"] },
    fr: { year:"2023–2026", title:"Loi immigration et accord Ciotti", details:["Décembre 2023 : loi immigration adoptée avec les voix RN — première fois sous Macron","Bardella : 'victoire idéologique du RN, les mesures ressorties de la CMP sont les nôtres'","Juin 2024 : Ciotti (LR) annonce l'alliance avec le RN aux législatives","Retailleau refuse de soutenir Estrosi contre le RN à Nice"], sources:["vie-publique.fr","Chapoutot (2025)","Le Monde, juin 2024"] }
  },
  {
    id: 4, label: "Capture", sublabel: "Prise du pouvoir légale",
    desc: "L'extrême droite accède au pouvoir par voie légale. Les modérés rallient par opportunisme ou résignation.",
    it: { year:"1922–1924", title:"Prise du pouvoir légale", details:["Mussolini nommé premier ministre le 30 octobre 1922 — procédure constitutionnelle","Loi Acerbo (1923) : prime de 65% des sièges pour le parti vainqueur","Élections d'avril 1924 : 65% pour la liste fasciste (avec fraudes)","Assassinat Matteotti (1924) : crise surmontée grâce à l'inaction des oppositions"], sources:["Milza (1999)","Matard-Bonucci (2012)"] },
    de: { year:"1933", title:"30 janvier — Chancellerie", details:["30 janvier 1933 : Hitler nommé chancelier par Hindenburg","27 février : incendie du Reichstag attribué aux communistes","28 février : décret — suspension de toutes les libertés constitutionnelles","5 mars : élections avec 44% (état d'urgence, presse interdite)"], sources:["Evans (2003)","Chapoutot, La Loi du sang (2014)"] },
    fr: { year:"Non atteint", title:"Phase non atteinte", details:["Le RN n'est pas au pouvoir national","Verrous actifs : second tour majoritaire, UE, Conseil constitutionnel","Dissolution de l'AN en juin 2024, montée aux législatives","Scénario de risque à surveiller en 2027"], sources:["Analyse La Bascule v0.1.0-draft"] }
  },
  {
    id: 5, label: "Consolidation", sublabel: "Destruction des contre-pouvoirs",
    desc: "Le régime démantèle méthodiquement les syndicats, la presse libre et les corps intermédiaires qui pourraient s'opposer.",
    it: { year:"1924–1926", title:"Discours du 3 janvier", details:["3 janvier 1925 : Mussolini assume la responsabilité du meurtre Matteotti","Loi sur la presse (1925) : journaux dirigés par des membres du PNF","Loi Rocco (1926) : dissolution des syndicats libres, seuls syndicats fascistes autorisés","Grève pénalement interdite"], sources:["Matard-Bonucci (2012)","Franzinelli, Il tribunale del duce (2017)"] },
    de: { year:"1933", title:"Destruction en 6 mois", details:["2 mai 1933 : dissolution des syndicats libres, locaux occupés par les SA","22 juin 1933 : SPD interdit, fonds confisqués","14 juillet 1933 : loi interdisant tout nouveau parti — parti unique","4 700 journaux sous contrôle nazi en 12 mois"], sources:["Evans, The Third Reich in Power (2005)","Chapoutot (2014)"] },
    fr: { year:"Non atteint", title:"Phase non atteinte", details:["Syndicats actifs et indépendants (CGT, CFDT, FO)","Presse d'opposition existante","Justice indépendante — CC a censuré 35 articles de la loi immigration","Liberté d'association garantie"], sources:["Analyse La Bascule v0.1.0-draft"] }
  },
  {
    id: 6, label: "Hégémonie", sublabel: "Dissolution du pluralisme",
    desc: "Tous les contre-pouvoirs sont détruits. L'opposition est criminalisée. Le pluralisme démocratique a disparu.",
    it: { year:"1926", title:"Lois fascistissimes", details:["Novembre 1926 : tous les partis non fascistes dissous","Tribunal spécial : 4 596 condamnations jusqu'en 1943","Rétablissement de la peine de mort pour délits politiques","Gramsci arrêté : 'nous devons faire taire ce cerveau pendant vingt ans'"], sources:["Matard-Bonucci (2012)","Gramsci, Lettres de prison (1926-1937)"] },
    de: { year:"1933–1934", title:"Loi d'habilitation", details:["23 mars 1933 : 441 voix pour, 94 contre (seuls les SPD refusent)","Hitler gouverne par décrets sans contrôle parlementaire","Nuit des longs couteaux (30 juin 1934) : liquidation des opposants internes","2 août 1934 : Hitler cumule chancelier et président"], sources:["Evans (2003)","Kershaw, Hitler 1936-1945 (2000)"] },
    fr: { year:"Non atteint", title:"Phase non atteinte", details:["France en phase 3 — phases 4, 5 et 6 non engagées","Distance structurelle importante avec les séquences historiques","L'UE comme verrou institutionnel supplémentaire","Le baromètre documente l'évolution en temps réel"], sources:["Analyse La Bascule v0.1.0-draft"] }
  },
];
---

<Base
  title="Frise historique"
  description="Frise comparative verticale des séquences de bascule autoritaire — Italie, Allemagne, France — phase par phase."
>

  <!-- ── Bandeau ── -->
  <div class="bandeau">
    <div class="bandeau-left">
      <span class="bandeau-label">Observatoire La Bascule</span>
      <span class="sep">·</span>
      <span class="bandeau-pos">France 2026 — <strong>Phase {phaseActiveFrance} / 6</strong></span>
    </div>
    <div class="bandeau-right">
      {derniereFiche && (
        <>
          <span class="bandeau-label">Dernière analyse ·</span>
          <span class="bandeau-fiche">{derniereFiche.source?.reference?.substring(0, 50)}…</span>
          <span class={`signal ${signalCls[signalFrance] || 'signal-none'}`}>
            {signalLabel[signalFrance] || '—'} {scoreFrance}%
          </span>
        </>
      )}
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/barometre`} class="bandeau-link">Baromètre →</a>
    </div>
  </div>

  <!-- ── Intro ── -->
  <div class="intro">
    <p class="label">Analyse comparative historique</p>
    <h1>Frise des bascules</h1>
    <p class="lead">
      Sept phases communes aux bascules fascistes historiques, appliquées
      en parallèle à l'Italie (1919–1926), l'Allemagne (1919–1933)
      et la France contemporaine (2015–2026).
    </p>
    <div class="disclaimer">
      ⚠️ Ce projet documente des <strong>similitudes de mécanismes</strong>, non une
      équivalence de nature. La France est en phase&nbsp;{phaseActiveFrance} — pas en 1933.
    </div>
  </div>

  <!-- ── En-têtes colonnes (sticky) ── -->
  <div class="frise-header">
    <div class="col-phase"></div>
    <div class="col-country it">
      <span class="flag">🇮🇹</span>
      <span class="country-name">Italie 1919–1926</span>
      <span class="outcome bad">Dictature en 1926</span>
    </div>
    <div class="col-country de">
      <span class="flag">🇩🇪</span>
      <span class="country-name">Allemagne 1919–1933</span>
      <span class="outcome bad">Dictature en 1933</span>
    </div>
    <div class="col-country fr">
      <span class="flag">🇫🇷</span>
      <span class="country-name">France 2015–2026</span>
      <span class="outcome watch">Phase {phaseActiveFrance} — en cours</span>
    </div>
  </div>

  <!-- ── Corps ── -->
  <div class="frise-body">
    {phases.map((p) => {
      const past    = p.id < phaseActiveFrance;
      const current = p.id === phaseActiveFrance;
      const future  = p.id > phaseActiveFrance;
      return (
        <div class:list={['frise-row', { 'row-past': past, 'row-current': current, 'row-future': future }]}>

          <!-- Phase -->
          <div class="col-phase-body">
            <div class:list={['phase-dot', { 'dot-past': past, 'dot-current': current }]}>
              <span class="dot-num">{p.id}</span>
            </div>
            <div class="phase-info">
              <strong class="phase-name">{p.label}</strong>
              <span class="phase-sub">{p.sublabel}</span>
              <p class="phase-desc">{p.desc}</p>
            </div>
            {current && <span class="cursor-tag">◀ France ici</span>}
          </div>

          <!-- Italie -->
          <div class="col-event it-event">
            <span class="ev-year" style="color:#8a3a00">{p.it.year}</span>
            <strong class="ev-title">{p.it.title}</strong>
            <ul class="ev-list">
              {p.it.details.map(d => <li>{d}</li>)}
            </ul>
            <div class="ev-sources">{p.it.sources.map(s => <span class="ev-src">{s}</span>)}</div>
          </div>

          <!-- Allemagne -->
          <div class="col-event de-event">
            <span class="ev-year" style="color:#4a2800">{p.de.year}</span>
            <strong class="ev-title">{p.de.title}</strong>
            <ul class="ev-list">
              {p.de.details.map(d => <li>{d}</li>)}
            </ul>
            <div class="ev-sources">{p.de.sources.map(s => <span class="ev-src">{s}</span>)}</div>
          </div>

          <!-- France -->
          <div class:list={['col-event', 'fr-event', { 'fr-current': current }]}>
            <span class="ev-year" style="color:#1a3a6a">{p.fr.year}</span>
            <strong class="ev-title">{p.fr.title}</strong>
            <ul class="ev-list">
              {p.fr.details.map(d => <li>{d}</li>)}
            </ul>
            <div class="ev-sources">{p.fr.sources.map(s => <span class="ev-src">{s}</span>)}</div>
          </div>

        </div>
      );
    })}
  </div>

  <hr class="divider" />

  <div class="sources-note">
    <p class="label">Méthode et sources</p>
    <p>
      Grille de 17 critères — Paxton (2004), Gramsci (1929-1935),
      Chapoutot (2025), Evans (2003), Milza (1999).
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/methode`}>Méthode complète →</a>
      &nbsp;·&nbsp;
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/barometre`}>Baromètre →</a>
    </p>
  </div>

</Base>

<style>
  /* ── Bandeau ── */
  .bandeau {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    background: var(--ink);
    color: var(--paper);
    padding: 0.6rem 1.5rem;
    margin: -3rem -2rem 2.5rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }
  .bandeau-left, .bandeau-right {
    display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap;
  }
  .bandeau-label { color: #666; text-transform: uppercase; }
  .sep { color: #444; }
  .bandeau-pos { color: #ccc; }
  .bandeau-pos strong { color: #fff; font-weight: 500; }
  .bandeau-fiche { color: #999; }
  .bandeau-link {
    color: var(--paper); border-bottom: 1px solid #444;
    text-decoration: none; transition: border-color 0.15s;
  }
  .bandeau-link:hover { border-color: var(--paper); }
  .bandeau .signal { font-size: 0.62rem; padding: 0.12rem 0.45rem; }

  /* ── Intro ── */
  .intro { margin-bottom: 2rem; }
  .disclaimer {
    font-size: 0.875rem;
    background: var(--bg-low);
    border-left: 3px solid var(--signal-low);
    padding: 0.7rem 1rem;
    margin-top: 1.25rem;
    color: var(--ink-light);
    border-radius: 0 2px 2px 0;
  }

  /* ── En-têtes (sticky) ── */
  .frise-header {
    display: grid;
    grid-template-columns: 200px 1fr 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 4px 4px 0 0;
    overflow: hidden;
    position: sticky;
    top: 58px;
    z-index: 20;
  }
  .col-phase { background: var(--paper-dark); }
  .col-country {
    display: flex; flex-direction: column; gap: 0.2rem;
    padding: 0.7rem 1rem;
    background: var(--paper-dark);
  }
  .flag { font-size: 1rem; line-height: 1; }
  .country-name {
    font-family: var(--display); font-size: 0.85rem;
    font-weight: 700; color: var(--ink);
  }
  .outcome {
    font-family: var(--mono); font-size: 0.6rem;
    letter-spacing: 0.07em; text-transform: uppercase;
  }
  .bad   { color: var(--signal-crit); }
  .watch { color: var(--signal-mid); }

  /* ── Corps ── */
  .frise-body {
    display: flex; flex-direction: column; gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-top: none;
    border-radius: 0 0 4px 4px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .frise-row {
    display: grid;
    grid-template-columns: 200px 1fr 1fr 1fr;
    gap: 1px;
    background: var(--rule);
  }
  .row-future { opacity: 0.5; }
  .row-current { background: rgba(138,58,0,0.12); }

  /* ── Phase col ── */
  .col-phase-body {
    display: flex; gap: 0.8rem; align-items: flex-start;
    padding: 1.25rem 0.9rem;
    background: var(--paper-dark);
    position: relative;
  }
  .phase-dot {
    flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--paper); border: 1.5px solid var(--rule);
    margin-top: 2px;
  }
  .dot-past    { background: var(--ink); border-color: var(--ink); }
  .dot-current { background: #8a3a00; border-color: #8a3a00; }
  .dot-num {
    font-family: var(--mono); font-size: 0.72rem; font-weight: 500;
    color: var(--ink-faint);
  }
  .dot-past .dot-num,
  .dot-current .dot-num { color: #fff; }

  .phase-info { display: flex; flex-direction: column; gap: 0.12rem; }
  .phase-name { font-family: var(--serif); font-size: 0.88rem; font-weight: 400; color: var(--ink); }
  .phase-sub {
    font-family: var(--mono); font-size: 0.58rem;
    text-transform: uppercase; letter-spacing: 0.07em; color: var(--ink-faint);
  }
  .phase-desc {
    font-size: 0.76rem; color: var(--ink-light);
    line-height: 1.45; margin-top: 0.3rem;
  }
  .cursor-tag {
    font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.05em;
    color: #8a3a00; position: absolute; bottom: 0.6rem; right: 0.6rem;
  }

  /* ── Event cols ── */
  .col-event {
    padding: 1.25rem 1rem;
    background: var(--paper);
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .it-event { background: #faf7f3; }
  .de-event { background: #f7f5f0; }
  .fr-event { background: #f5f3f8; }
  .fr-current {
    background: #fef6ec;
    border-left: 2px solid #8a3a00;
    padding-left: 0.9rem;
  }

  .ev-year {
    font-family: var(--mono); font-size: 0.63rem; letter-spacing: 0.04em;
  }
  .ev-title {
    font-family: var(--serif); font-size: 0.875rem; font-weight: 400;
    color: var(--ink); line-height: 1.3;
  }
  .ev-list {
    list-style: none; padding: 0;
    display: flex; flex-direction: column; gap: 0.28rem;
    margin-top: 0.2rem;
  }
  .ev-list li {
    font-size: 0.77rem; color: var(--ink-light); line-height: 1.45;
    padding-left: 0.9rem; position: relative;
  }
  .ev-list li::before {
    content: '—'; position: absolute; left: 0;
    color: var(--rule); font-size: 0.68rem;
  }
  .ev-sources {
    display: flex; flex-wrap: wrap; gap: 0.3rem;
    margin-top: auto; padding-top: 0.5rem;
    border-top: 1px solid var(--rule);
  }
  .ev-src {
    font-family: var(--mono); font-size: 0.58rem;
    color: var(--ink-faint); letter-spacing: 0.02em;
  }

  /* ── Sources ── */
  .sources-note { font-size: 0.85rem; color: var(--ink-faint); }
  .sources-note p { line-height: 1.7; }
  .sources-note a { color: var(--ink-light); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .frise-header, .frise-row {
      grid-template-columns: 130px 1fr 1fr 1fr;
    }
    .phase-desc { display: none; }
    .ev-list    { display: none; }
  }
  @media (max-width: 600px) {
    .frise-header { display: none; }
    .frise-row { grid-template-columns: 1fr; }
    .col-phase-body { background: var(--ink); }
    .phase-name, .phase-desc { color: var(--paper); }
    .phase-sub { color: #888; }
    .col-event { border-top: 1px solid var(--rule); }
  }
</style>

<!-- Inline component pour les blocs d'événements -->
<script>
  // Rien — tout est Astro SSG
</script>
